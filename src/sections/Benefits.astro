---
import { Store, Clock, DollarSign, Eye, Zap, ShieldCheck, Map, CreditCard, Check } from '@lucide/astro';
---

<!-- Benefits Section: Asymmetric Bento Grid -->
<section id="benefits" class="py-32 bg-white border-t border-slate-200 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="text-center max-w-2xl mx-auto mb-20">
            <span class="inline-block px-4 py-1.5 rounded-full bg-slate-100 text-slate-700 font-bold text-sm mb-4 border border-slate-200 shadow-sm">Benefits</span>
            <h2 class="font-display text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-6">Designed for Modern Living</h2>
            <p class="text-lg text-slate-500">Pressly makes laundry completely hands-off so you can focus on what matters most.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Span 2: Nearby Shops -->
            <div class="md:col-span-2 bg-slate-50 border border-slate-200 rounded-[2.5rem] p-10 flex flex-col justify-between group hover:bg-slate-100 transition-colors relative overflow-hidden shadow-sm hover:shadow-md">
                <div class="absolute right-0 bottom-0 opacity-10 group-hover:opacity-20 transition-opacity translate-x-1/4 translate-y-1/4">
                    <Map class="w-64 h-64 text-primary" />
                </div>
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-white shadow-sm flex items-center justify-center text-primary mb-6"><Store class="w-7 h-7" /></div>
                    <h3 class="text-2xl font-bold text-slate-900 mb-3">Nearby Shops</h3>
                    <p class="text-slate-600 max-w-md leading-relaxed">Instantly discover and select the highest-rated professional ironing services right in your local neighborhood, visualized on a live map.</p>
                </div>
            </div>

            <!-- Span 1: Flexible Pickup -->
            <div class="bg-slate-900 border border-slate-800 rounded-[2.5rem] p-10 text-white flex flex-col justify-between group hover:bg-slate-800 transition-colors shadow-sm hover:shadow-xl hover:shadow-slate-900/20">
                <div>
                    <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center text-white mb-6 backdrop-blur-sm"><Clock class="w-7 h-7" /></div>
                    <h3 class="text-2xl font-bold mb-3">Flexible Pickup</h3>
                    <p class="text-slate-400 leading-relaxed text-sm">Book precise 1-hour slots that perfectly fit your calendar.</p>
                </div>
            </div>

            <!-- Span 1: Simple Pricing -->
            <div class="bg-emerald-500 border border-emerald-600 rounded-[2.5rem] p-10 text-white flex flex-col justify-between group hover:bg-emerald-400 transition-colors relative overflow-hidden shadow-sm hover:shadow-xl hover:shadow-emerald-500/30">
                <div class="absolute right-[-20px] top-[-20px] opacity-20"><DollarSign class="w-40 h-40" /></div>
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center text-white mb-6 backdrop-blur-sm"><CreditCard class="w-7 h-7" /></div>
                    <h3 class="text-2xl font-bold mb-3">Simple Pricing</h3>
                    <p class="text-emerald-50 leading-relaxed text-sm">Clear, transparent per-item rate cards shown upfront. Pay securely.</p>
                </div>
            </div>

            <!-- Span 2: Order Tracking -->
            <div class="md:col-span-2 bg-slate-50 border border-slate-200 rounded-[2.5rem] p-10 flex flex-col md:flex-row gap-8 items-center justify-between group hover:bg-slate-100 transition-colors shadow-sm hover:shadow-md">
                <div class="md:w-1/2">
                    <div class="w-14 h-14 rounded-2xl bg-white shadow-sm flex items-center justify-center text-rose-500 mb-6"><Eye class="w-7 h-7" /></div>
                    <h3 class="text-2xl font-bold text-slate-900 mb-3">Live Order Tracking</h3>
                    <p class="text-slate-600 leading-relaxed">Monitor your laundry from transit to ironing board to delivery with real-time tracking inside the app.</p>
                </div>
                <div class="md:w-1/2 w-full bg-white rounded-2xl p-6 shadow-inner border border-slate-100">
                    <div class="flex items-center gap-4 mb-5">
                        <div class="w-8 h-8 rounded-full bg-rose-100 flex items-center justify-center text-rose-600 shrink-0"><Check class="w-4 h-4"/></div>
                        <div class="h-2 flex-1 bg-slate-100 rounded-full"><div class="w-full h-full bg-rose-500 rounded-full"></div></div>
                    </div>
                    <div class="flex items-center gap-4 mb-5">
                        <div class="w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center text-amber-600 shrink-0"><Zap class="w-4 h-4"/></div>
                        <div class="h-2 flex-1 bg-slate-100 rounded-full"><div class="w-1/2 h-full bg-amber-500 rounded-full"></div></div>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 shrink-0"><Store class="w-4 h-4"/></div>
                        <div class="h-2 flex-1 bg-slate-100 rounded-full"></div>
                    </div>
                </div>
            </div>

            <!-- Span 1 (Fast Delivery) -->
            <div class="bg-amber-50 border border-amber-100 rounded-[2.5rem] p-10 flex flex-col justify-between group hover:bg-amber-100 transition-colors shadow-sm hover:shadow-md">
                <div>
                    <div class="w-14 h-14 rounded-2xl bg-white shadow-sm flex items-center justify-center text-amber-500 mb-6"><Zap class="w-7 h-7" /></div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">Fast Delivery</h3>
                    <p class="text-amber-900/70 leading-relaxed text-sm">Express 12-hour or standard 24-hour turnaround options.</p>
                </div>
            </div>

            <!-- Span 2 (Reliable) -->
            <div class="md:col-span-2 bg-slate-50 border border-slate-200 rounded-[2.5rem] p-10 flex flex-col justify-between group hover:bg-slate-100 transition-colors shadow-sm hover:shadow-md">
                <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-8">
                    <div class="w-16 h-16 rounded-2xl bg-white shadow-sm flex items-center justify-center text-teal-600 shrink-0"><ShieldCheck class="w-8 h-8" /></div>
                    <div>
                        <h3 class="text-2xl font-bold text-slate-900 mb-3">Reliable Vendors</h3>
                        <p class="text-slate-600 leading-relaxed">Rest easy knowing every vendor is vetted, rating-reviewed, and committed to high-end garment protection.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
