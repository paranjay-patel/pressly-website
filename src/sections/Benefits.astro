---
import { Store, Clock, DollarSign, Eye, Zap, ShieldCheck } from '@lucide/astro';
---

<section id="benefits" class="py-32 bg-slate-50 border-t border-slate-200 relative overflow-hidden">
	<div class="max-w-7xl mx-auto px-6 relative z-10">
		<!-- Section Header -->
		<div class="text-center max-w-2xl mx-auto mb-20">
			<span class="inline-block px-4 py-1.5 rounded-full bg-white text-primary font-bold text-sm mb-4 border border-slate-200 shadow-sm">Benefits</span>
			<h2 class="font-display text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-6">Designed for Modern Living</h2>
			<p class="text-lg text-slate-600">Pressly makes laundry completely hands-off so you can focus on what matters most.</p>
		</div>

		<!-- 3x2 Benefits Grid -->
		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
			
			<!-- Benefit 1: Nearby Shops -->
			<div class="group bg-white border border-slate-200/80 rounded-[2.5rem] p-8 shadow-sm hover:shadow-md hover:border-slate-300 transition-all duration-300">
				<div class="w-14 h-14 rounded-2xl bg-sky-50 flex items-center justify-center text-sky-600 mb-6 group-hover:scale-110 transition-transform">
					<Store class="w-7 h-7" />
				</div>
				<h3 class="text-xl font-bold text-slate-900 mb-3">Nearby Shops</h3>
				<p class="text-sm text-slate-600 leading-relaxed">Instantly discover and select the highest-rated professional ironing services right in your local neighborhood.</p>
			</div>

			<!-- Benefit 2: Flexible Pickup -->
			<div class="group bg-white border border-slate-200/80 rounded-[2.5rem] p-8 shadow-sm hover:shadow-md hover:border-slate-300 transition-all duration-300">
				<div class="w-14 h-14 rounded-2xl bg-sky-50 flex items-center justify-center text-sky-500 mb-6 group-hover:scale-110 transition-transform">
					<Clock class="w-7 h-7" />
				</div>
				<h3 class="text-xl font-bold text-slate-900 mb-3">Flexible Pickup</h3>
				<p class="text-sm text-slate-600 leading-relaxed">Book precise 1-hour slots that perfectly fit your calendar. Our pickup partners operate around your schedule.</p>
			</div>

			<!-- Benefit 3: Simple Pricing -->
			<div class="group bg-white border border-slate-200/80 rounded-[2.5rem] p-8 shadow-sm hover:shadow-md hover:border-slate-300 transition-all duration-300">
				<div class="w-14 h-14 rounded-2xl bg-emerald-50 flex items-center justify-center text-emerald-600 mb-6 group-hover:scale-110 transition-transform">
					<DollarSign class="w-7 h-7" />
				</div>
				<h3 class="text-xl font-bold text-slate-900 mb-3">Simple Pricing</h3>
				<p class="text-sm text-slate-600 leading-relaxed">Clear, transparent per-item rate cards shown upfront. Pay securely online via UPI or card with zero hidden fees.</p>
			</div>

			<!-- Benefit 4: Order Tracking -->
			<div class="group bg-white border border-slate-200/80 rounded-[2.5rem] p-8 shadow-sm hover:shadow-md hover:border-slate-300 transition-all duration-300">
				<div class="w-14 h-14 rounded-2xl bg-rose-50 flex items-center justify-center text-rose-600 mb-6 group-hover:scale-110 transition-transform">
					<Eye class="w-7 h-7" />
				</div>
				<h3 class="text-xl font-bold text-slate-900 mb-3">Order Tracking</h3>
				<p class="text-sm text-slate-600 leading-relaxed">Monitor your laundry from transit to ironing board to delivery with real-time tracking inside the app.</p>
			</div>

			<!-- Benefit 5: Fast Delivery -->
			<div class="group bg-white border border-slate-200/80 rounded-[2.5rem] p-8 shadow-sm hover:shadow-md hover:border-slate-300 transition-all duration-300">
				<div class="w-14 h-14 rounded-2xl bg-amber-50 flex items-center justify-center text-amber-600 mb-6 group-hover:scale-110 transition-transform">
					<Zap class="w-7 h-7" />
				</div>
				<h3 class="text-xl font-bold text-slate-900 mb-3">Fast Delivery</h3>
				<p class="text-sm text-slate-600 leading-relaxed">Need it fresh and fast? Select our express 12-hour or standard 24-hour turnaround options for your outfits.</p>
			</div>

			<!-- Benefit 6: Reliable Vendors -->
			<div class="group bg-white border border-slate-200/80 rounded-[2.5rem] p-8 shadow-sm hover:shadow-md hover:border-slate-300 transition-all duration-300">
				<div class="w-14 h-14 rounded-2xl bg-teal-50 flex items-center justify-center text-teal-600 mb-6 group-hover:scale-110 transition-transform">
					<ShieldCheck class="w-7 h-7" />
				</div>
				<h3 class="text-xl font-bold text-slate-900 mb-3">Reliable Vendors</h3>
				<p class="text-sm text-slate-600 leading-relaxed">Rest easy knowing every vendor is vetted, rating-reviewed, and committed to high-end garment protection.</p>
			</div>

		</div>
	</div>
</section>
