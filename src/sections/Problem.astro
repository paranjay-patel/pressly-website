---
import { Frown, XCircle, CheckCircle2, DollarSign, Calendar, PhoneCall, PhoneOff, EyeOff, Eye, ShieldAlert } from '@lucide/astro';
---

<!-- Interactive Tabs Section -->
<section class="py-24 bg-slate-50 border-t border-slate-200 relative overflow-hidden" id="problem-tabs-section">
	<div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
		
		<div class="mb-12 pt-8">
			<h2 class="font-display text-3xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-4">The Laundry Dilemma</h2>
			<p class="text-lg text-slate-600">See how Pressly transforms your daily chore.</p>
		</div>

		<!-- Tabs UI -->
		<div class="bg-white border border-slate-200 p-2 rounded-full inline-flex mb-8 relative">
			<button class="tab-btn active px-8 py-3 rounded-full font-bold relative z-10 transition-colors text-rose-700" data-target="old-way">The Old Way</button>
			<button class="tab-btn px-8 py-3 rounded-full font-bold relative z-10 transition-colors text-slate-500 hover:text-slate-900" data-target="pressly-way">The Pressly Way</button>
			<div class="tab-indicator absolute top-2 bottom-2 left-2 w-[140px] bg-rose-50 border border-rose-100 rounded-full transition-all duration-300 ease-out z-0"></div>
		</div>

		<!-- Grid Stacking Trick for smooth cross-fading without height jumping -->
		<div class="grid grid-cols-1 grid-rows-1">
			<!-- The Old Way Content (Light with Red Accents) -->
			<div id="old-way" class="tab-content col-start-1 row-start-1 bg-white rounded-[3rem] p-8 md:p-12 text-left shadow-lg border border-rose-100 transition-all duration-500 opacity-100 translate-y-0 z-10">
				<div class="grid md:grid-cols-2 gap-8 md:gap-12">
					<div class="space-y-8">
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-2xl bg-rose-50 flex items-center justify-center shrink-0 border border-rose-100"><DollarSign class="w-6 h-6 text-rose-500" /></div>
							<div>
								<h4 class="font-bold text-slate-900 mb-1">No Pricing Visibility</h4>
								<p class="text-slate-600 text-sm leading-relaxed">Haggling and surprise charges at the door.</p>
							</div>
						</div>
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-2xl bg-rose-50 flex items-center justify-center shrink-0 border border-rose-100"><PhoneOff class="w-6 h-6 text-rose-500" /></div>
							<div>
								<h4 class="font-bold text-slate-900 mb-1">Hard to Contact</h4>
								<p class="text-slate-600 text-sm leading-relaxed">Unanswered calls and chasing vendors.</p>
							</div>
						</div>
					</div>
					<div class="space-y-8">
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-2xl bg-rose-50 flex items-center justify-center shrink-0 border border-rose-100"><Calendar class="w-6 h-6 text-rose-500" /></div>
							<div>
								<h4 class="font-bold text-slate-900 mb-1">No Scheduling</h4>
								<p class="text-slate-600 text-sm leading-relaxed">Wait around all day for random pickups.</p>
							</div>
						</div>
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-2xl bg-rose-50 flex items-center justify-center shrink-0 border border-rose-100"><EyeOff class="w-6 h-6 text-rose-500" /></div>
							<div>
								<h4 class="font-bold text-slate-900 mb-1">No Order Tracking</h4>
								<p class="text-slate-600 text-sm leading-relaxed">Zero visibility on your lost garments.</p>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- The Pressly Way Content (Solid Green) -->
			<div id="pressly-way" class="tab-content col-start-1 row-start-1 bg-emerald-600 rounded-[3rem] p-8 md:p-12 text-left shadow-[0_20px_40px_-15px_rgba(5,150,105,0.4)] border border-emerald-700 transition-all duration-500 opacity-0 translate-y-8 pointer-events-none z-0">
				<div class="grid md:grid-cols-2 gap-8 md:gap-12">
					<div class="space-y-8">
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-2xl bg-white/20 flex items-center justify-center shrink-0"><DollarSign class="w-6 h-6 text-white" /></div>
							<div>
								<h4 class="font-bold text-white mb-1">Transparent Pricing</h4>
								<p class="text-emerald-100 text-sm leading-relaxed">View exact vendor rate cards upfront.</p>
							</div>
						</div>
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-2xl bg-white/20 flex items-center justify-center shrink-0"><PhoneCall class="w-6 h-6 text-white" /></div>
							<div>
								<h4 class="font-bold text-white mb-1">Instant Support</h4>
								<p class="text-emerald-100 text-sm leading-relaxed">In-app chat and quick calls.</p>
							</div>
						</div>
					</div>
					<div class="space-y-8">
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-2xl bg-white/20 flex items-center justify-center shrink-0"><Calendar class="w-6 h-6 text-white" /></div>
							<div>
								<h4 class="font-bold text-white mb-1">Flexible Scheduling</h4>
								<p class="text-emerald-100 text-sm leading-relaxed">Choose a precise 1-hour window.</p>
							</div>
						</div>
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-2xl bg-white/20 flex items-center justify-center shrink-0"><Eye class="w-6 h-6 text-white" /></div>
							<div>
								<h4 class="font-bold text-white mb-1">Live Tracking</h4>
								<p class="text-emerald-100 text-sm leading-relaxed">Track your clothes in real-time.</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const btns = document.querySelectorAll('.tab-btn');
			const contents = document.querySelectorAll('.tab-content');
			const indicator = document.querySelector('.tab-indicator');
			
			if(!btns.length) return;

			setTimeout(() => {
				indicator.style.width = `${btns[0].offsetWidth}px`;
			}, 100);

			btns.forEach((btn) => {
				btn.addEventListener('click', () => {
					// Slide indicator
					indicator.style.transform = `translateX(${btn.offsetLeft - 8}px)`;
					indicator.style.width = `${btn.offsetWidth}px`;
					
					// Change indicator color depending on the active tab
					if(btn.getAttribute('data-target') === 'pressly-way') {
						indicator.className = 'tab-indicator absolute top-2 bottom-2 left-2 bg-emerald-600 shadow-md rounded-full transition-all duration-300 ease-out z-0';
					} else {
						indicator.className = 'tab-indicator absolute top-2 bottom-2 left-2 bg-rose-50 border border-rose-100 rounded-full transition-all duration-300 ease-out z-0';
					}
					
					// Update text colors
					btns.forEach(b => {
						b.classList.remove('text-white', 'text-rose-700');
						b.classList.add('text-slate-500');
					});
					
					btn.classList.remove('text-slate-500');
					if(btn.getAttribute('data-target') === 'pressly-way') {
						btn.classList.add('text-white');
					} else {
						btn.classList.add('text-rose-700');
					}

					// Crossfade content panels
					const targetId = btn.getAttribute('data-target');
					contents.forEach(content => {
						if (content.id === targetId) {
							content.classList.remove('opacity-0', 'translate-y-8', 'pointer-events-none', 'z-0');
							content.classList.add('opacity-100', 'translate-y-0', 'z-10');
						} else {
							content.classList.remove('opacity-100', 'translate-y-0', 'z-10');
							content.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none', 'z-0');
						}
					});
				});
			});
		});
	</script>
</section>
