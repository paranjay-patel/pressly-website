---
import { Frown, XCircle, CheckCircle2, DollarSign, Calendar, PhoneCall, PhoneOff, EyeOff, Eye, ShieldAlert } from '@lucide/astro';
---

<!-- Problem Section -->
<section id="problem-section" class="py-24 bg-white border-t border-slate-200 overflow-hidden relative">
	<!-- Subtle background glassmorphism details -->
	<div class="absolute top-1/2 left-0 w-80 h-80 bg-rose-50 rounded-full blur-3xl opacity-60 -translate-y-1/2 -translate-x-1/2 -z-10"></div>
	<div class="absolute top-1/3 right-0 w-80 h-80 bg-emerald-50 rounded-full blur-3xl opacity-60 -translate-y-1/2 translate-x-1/2 -z-10"></div>

	<div class="max-w-7xl mx-auto px-6">
		<div class="text-center max-w-2xl mx-auto mb-16">
			<span class="inline-block px-4 py-1.5 rounded-full bg-rose-50 text-rose-600 font-semibold text-sm mb-4 border border-rose-100">The Laundry Dilemma</span>
			<h2 class="font-display text-3xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-6">Tired of the Traditional Dhobi?</h2>
			<p class="text-lg text-slate-600">Traditional ironing is full of stress, uncertainty, and lost garments. Here is why the old way is broken.</p>
		</div>

		<div class="grid lg:grid-cols-2 gap-12 items-stretch">
			<!-- The Old Way -->
			<div class="bg-rose-50 border border-rose-100 rounded-[2.5rem] p-8 md:p-10 flex flex-col justify-between shadow-xl shadow-rose-100/10">
				<div>
					<div class="flex items-center gap-3 mb-8">
						<div class="w-10 h-10 rounded-full bg-rose-100 flex items-center justify-center text-rose-600"><XCircle class="w-6 h-6" /></div>
						<h3 class="font-display text-2xl font-bold text-slate-900">The Frustrating Old Way</h3>
					</div>
					
					<div class="space-y-8">
						<!-- Pricing Visibility -->
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center shrink-0 shadow-sm"><DollarSign class="w-6 h-6 text-rose-500" /></div>
							<div>
								<h4 class="font-bold text-slate-900 mb-1">No Pricing Visibility</h4>
								<p class="text-slate-600 text-sm md:text-base leading-relaxed">No fixed rate cards. You get surprised by high prices during delivery, and cash-only requests.</p>
							</div>
						</div>

						<!-- Hard to Contact -->
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center shrink-0 shadow-sm"><PhoneOff class="w-6 h-6 text-rose-500" /></div>
							<div>
								<h4 class="font-bold text-slate-900 mb-1">Hard to Contact</h4>
								<p class="text-slate-600 text-sm md:text-base leading-relaxed">Chasing the vendor, making repeated unanswered phone calls, or physically looking for them.</p>
							</div>
						</div>

						<!-- No Scheduling -->
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center shrink-0 shadow-sm"><Calendar class="w-6 h-6 text-rose-500" /></div>
							<div>
								<h4 class="font-bold text-slate-900 mb-1">No Scheduling</h4>
								<p class="text-slate-600 text-sm md:text-base leading-relaxed">No way to select a pickup window. You have to wait around at home for random vendor arrivals.</p>
							</div>
						</div>

						<!-- No Order Tracking -->
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center shrink-0 shadow-sm"><EyeOff class="w-6 h-6 text-rose-500" /></div>
							<div>
								<h4 class="font-bold text-slate-900 mb-1">No Order Tracking</h4>
								<p class="text-slate-600 text-sm md:text-base leading-relaxed">Zero status visibility once your garments leave your hands. You just hope they return safely.</p>
							</div>
						</div>
					</div>
				</div>
				
				<div class="mt-8 pt-6 border-t border-rose-100 flex items-center gap-3 text-rose-600 font-semibold">
					<Frown class="w-5 h-5" /> Ruining expensive garments is a common reality.
				</div>
			</div>

			<!-- The Pressly Way -->
			<div class="bg-emerald-50 border border-emerald-100 rounded-[2.5rem] p-8 md:p-10 flex flex-col justify-between shadow-xl shadow-emerald-100/10">
				<div>
					<div class="flex items-center gap-3 mb-8">
						<div class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600"><CheckCircle2 class="w-6 h-6" /></div>
						<h3 class="font-display text-2xl font-bold text-slate-900">The Modern Pressly Way</h3>
					</div>

					<div class="space-y-8">
						<!-- Pricing Visibility -->
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center shrink-0 shadow-sm"><DollarSign class="w-6 h-6 text-emerald-500" /></div>
							<div>
								<h4 class="font-bold text-slate-900 mb-1">Transparent Pricing</h4>
								<p class="text-slate-600 text-sm md:text-base leading-relaxed">View exact vendor rate cards upfront on the app. Pay easily using UPI, card, or digital wallets.</p>
							</div>
						</div>

						<!-- Hard to Contact -->
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center shrink-0 shadow-sm"><PhoneCall class="w-6 h-6 text-emerald-500" /></div>
							<div>
								<h4 class="font-bold text-slate-900 mb-1">Instant Support & Chat</h4>
								<p class="text-slate-600 text-sm md:text-base leading-relaxed">In-app chat and quick call buttons connect you to your local vendor or support instantly.</p>
							</div>
						</div>

						<!-- No Scheduling -->
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center shrink-0 shadow-sm"><Calendar class="w-6 h-6 text-emerald-500" /></div>
							<div>
								<h4 class="font-bold text-slate-900 mb-1">Flexible Scheduling</h4>
								<p class="text-slate-600 text-sm md:text-base leading-relaxed">Choose a precise 1-hour pickup and delivery window that suits your daily schedule.</p>
							</div>
						</div>

						<!-- No Order Tracking -->
						<div class="flex gap-4">
							<div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center shrink-0 shadow-sm"><Eye class="w-6 h-6 text-emerald-500" /></div>
							<div>
								<h4 class="font-bold text-slate-900 mb-1">Live Order Tracking</h4>
								<p class="text-slate-600 text-sm md:text-base leading-relaxed">Track your clothes from transit to ironing to doorsteps in real-time, directly inside your app.</p>
							</div>
						</div>
					</div>
				</div>

				<div class="mt-8 pt-6 border-t border-emerald-100 flex items-center gap-3 text-emerald-600 font-semibold">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
					Save hours of laundry stress every single week.
				</div>
			</div>
		</div>
	</div>
</section>
