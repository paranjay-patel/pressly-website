---
import { HelpCircle, User, Store, CreditCard } from '@lucide/astro';

const faqs = [
	{
		category: "Customers",
		icon: User,
		color: "text-primary",
		bg: "bg-sky-50",
		items: [
			{ q: "How do I schedule a pickup?", a: "Simply open the Pressly app, select your preferred local vendor, choose a time slot, and confirm. The vendor will arrive at your door at the scheduled time." },
			{ q: "How are my clothes counted?", a: "To ensure 100% transparency, the vendor counts the clothes right in front of you at the time of pickup. The exact count is entered into the app and you instantly confirm it on your phone." },
			{ q: "Can I track my order?", a: "Yes! You can track your order status in real-time within the app. You'll receive notifications when your clothes are picked up, being ironed, and out for delivery." },
			{ q: "What happens if a piece of clothing is missing?", a: "Because we enforce a strict doorstep counting policy, the exact number of items is verified by both you and the vendor before the clothes ever leave your house. If a discrepancy occurs upon return, Pressly support will intervene and investigate using the verified digital receipt." }
		]
	},
	{
		category: "Vendors",
		icon: Store,
		color: "text-emerald-600",
		bg: "bg-emerald-50",
		items: [
			{ q: "How do I become a Pressly Partner?", a: "You can apply through our Partner page on this website. Fill out the basic details about your shop and location. Our local operations team will verify your shop within 24 hours." },
			{ q: "Is there a registration fee?", a: "No, joining Pressly is completely free for vendors. We only charge a small performance-based commission per successful order generated through our application." },
			{ q: "Do I need to hire delivery staff?", a: "Not necessarily. Many of our partners handle pickups and deliveries themselves within a 2km radius of their shop. However, if your order volume grows, you may choose to hire dedicated staff." },
			{ q: "How do I update my service area?", a: "You can easily adjust your service radius (e.g., from 1km to 3km) directly from your Partner Dashboard in the vendor app to control how far you are willing to travel for pickups." }
		]
	},
	{
		category: "Payments",
		icon: CreditCard,
		color: "text-rose-500",
		bg: "bg-rose-50",
		items: [
			{ q: "What payment methods are supported?", a: "We support all major payment methods including UPI (GPay, PhonePe, Paytm), Credit/Debit Cards, and Net Banking securely processed via Razorpay." },
			{ q: "Can I pay in cash?", a: "Currently, to maintain transparency and a seamless experience for both customers and vendors, we operate on a 100% digital payment model." },
			{ q: "When do vendors get paid?", a: "For vendors, all digital payments collected from customers are compiled and transferred directly to your registered bank account on a weekly basis (every Wednesday)." },
			{ q: "Are there any hidden fees?", a: "No hidden fees. The price you see on the app before confirming the order is the final price. We believe in absolute transparency." }
		]
	}
];
---

	<!-- FAQ List Section -->
	<section class="pb-24 pt-8 bg-slate-50 border-t border-slate-200">
		<div class="max-w-4xl mx-auto px-4 sm:px-6">
			
			<div id="no-results" class="hidden text-center py-20">
				<div class="w-20 h-20 bg-slate-100 text-slate-400 rounded-full flex items-center justify-center mx-auto mb-6">
					<svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"></path></svg>
				</div>
				<h3 class="text-2xl font-bold text-slate-900 mb-2">No results found</h3>
				<p class="text-slate-600">We couldn't find any FAQs matching your search.</p>
			</div>

			<div id="faq-container" class="space-y-16">
				{faqs.map((category) => (
					<div class="faq-category-group" data-category={category.category}>
						<!-- Category Header -->
						<div class="flex items-center gap-4 mb-8">
							<div class={`w-12 h-12 rounded-2xl ${category.bg} ${category.color} flex items-center justify-center shadow-sm`}>
								<category.icon class="w-6 h-6" />
							</div>
							<h2 class="font-display text-3xl font-bold text-slate-900">{category.category}</h2>
						</div>

						<!-- FAQ Items -->
						<div class="space-y-4">
							{category.items.map((faq) => (
								<details name="main-faq" class="faq-item group bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-md transition-all">
									<summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-slate-900 text-lg hover:bg-slate-50 transition-colors">
										<span class="faq-question">{faq.q}</span>
										<span class="transition group-open:rotate-180 text-primary shrink-0 ml-4">
											<HelpCircle class="w-5 h-5" />
										</span>
									</summary>
									<div class="faq-answer p-6 pt-0 border-t border-slate-100 text-slate-600 text-base leading-relaxed bg-slate-50/50">
										{faq.a}
									</div>
								</details>
							))}
						</div>
					</div>
				))}
			</div>
			
			<!-- Bottom CTA -->
			<div class="mt-20 bg-slate-900 rounded-[2rem] p-10 md:p-14 text-center relative overflow-hidden">
				<div class="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-primary/20 to-sky-500/20 opacity-50"></div>
				<div class="relative z-10">
					<h3 class="font-display text-3xl font-bold text-white mb-4">Still have questions?</h3>
					<p class="text-slate-300 mb-8 max-w-lg mx-auto text-lg">If you cannot find answer to your question in our FAQ, you can always contact us. We will answer to you shortly!</p>
					<a href="/contact" class="inline-flex items-center justify-center px-8 py-4 rounded-2xl font-bold text-lg bg-white text-slate-900 hover:bg-slate-100 hover:-translate-y-0.5 transition-all shadow-xl shadow-white/10">Contact Support</a>
				</div>
			</div>

		</div>
	</section>

	<script>
		// Client-side search logic
		const searchInput = document.getElementById('faq-search') as HTMLInputElement;
		const clearBtn = document.getElementById('search-clear-btn');
		const faqContainer = document.getElementById('faq-container');
		const noResults = document.getElementById('no-results');
		
		const groups = document.querySelectorAll('.faq-category-group');
		const items = document.querySelectorAll('.faq-item');

		function performSearch(query: string) {
			const lowerQuery = query.toLowerCase();
			let hasAnyMatch = false;

			// Show/hide clear button
			if (query.length > 0) {
				clearBtn?.classList.remove('hidden');
			} else {
				clearBtn?.classList.add('hidden');
			}

			groups.forEach(group => {
				let hasVisibleItemInGroup = false;
				const groupItems = group.querySelectorAll('.faq-item');

				groupItems.forEach(item => {
					const q = item.querySelector('.faq-question')?.textContent?.toLowerCase() || '';
					const a = item.querySelector('.faq-answer')?.textContent?.toLowerCase() || '';
					
					if (q.includes(lowerQuery) || a.includes(lowerQuery)) {
						(item as HTMLElement).style.display = 'block';
						hasVisibleItemInGroup = true;
						hasAnyMatch = true;
						
						// If searching, automatically open matched items
						if (query.length > 0) {
							(item as HTMLDetailsElement).open = true;
						} else {
							(item as HTMLDetailsElement).open = false; // close them when clearing
						}
					} else {
						(item as HTMLElement).style.display = 'none';
					}
				});

				// Hide category header if no items match in this category
				if (hasVisibleItemInGroup) {
					(group as HTMLElement).style.display = 'block';
				} else {
					(group as HTMLElement).style.display = 'none';
				}
			});

			if (hasAnyMatch) {
				faqContainer?.classList.remove('hidden');
				noResults?.classList.add('hidden');
			} else {
				faqContainer?.classList.add('hidden');
				noResults?.classList.remove('hidden');
			}
		}

		searchInput?.addEventListener('input', (e) => {
			performSearch((e.target as HTMLInputElement).value);
		});

		clearBtn?.addEventListener('click', () => {
			if (searchInput) {
				searchInput.value = '';
				performSearch('');
				searchInput.focus();
			}
		});
	</script>
