---
import { Shield, Zap, Sparkles, Heart } from '@lucide/astro';
---
	<!-- Values Section: Interactive Grid -->
	<section class="py-24 bg-slate-50 border-t border-slate-200">
		<div class="max-w-7xl mx-auto px-4 sm:px-6">
			<div class="text-center max-w-3xl mx-auto mb-16">
				<h2 class="font-display text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight">Core Values</h2>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
				<!-- Value 1 -->
				<div class="bg-white border border-slate-200 rounded-3xl p-8 hover:bg-slate-900 hover:text-white group transition-colors duration-300 cursor-default shadow-sm hover:shadow-xl">
					<div class="w-14 h-14 rounded-2xl bg-slate-50 border border-slate-100 text-slate-700 flex items-center justify-center mb-6 group-hover:bg-white/10 group-hover:border-white/20 group-hover:text-white transition-all duration-300 group-hover:scale-110">
						<Shield class="w-7 h-7" />
					</div>
					<h3 class="text-xl font-bold text-slate-900 group-hover:text-white mb-3 transition-colors">Absolute Transparency</h3>
					<p class="text-slate-600 group-hover:text-slate-300 text-sm leading-relaxed transition-colors">
						No hidden fees, no counting disputes. Doorstep verification ensures absolute truth.
					</p>
				</div>

				<!-- Value 2 -->
				<div class="bg-white border border-slate-200 rounded-3xl p-8 hover:bg-primary hover:text-white group transition-colors duration-300 cursor-default shadow-sm hover:shadow-xl">
					<div class="w-14 h-14 rounded-2xl bg-slate-50 border border-slate-100 text-slate-700 flex items-center justify-center mb-6 group-hover:bg-white/20 group-hover:border-white/20 group-hover:text-white transition-all duration-300 group-hover:scale-110">
						<Zap class="w-7 h-7" />
					</div>
					<h3 class="text-xl font-bold text-slate-900 group-hover:text-white mb-3 transition-colors">Seamless Convenience</h3>
					<p class="text-slate-600 group-hover:text-sky-100 text-sm leading-relaxed transition-colors">
						Scheduling and tracking laundry should be as effortless as ordering your favorite food.
					</p>
				</div>

				<!-- Value 3 -->
				<div class="bg-white border border-slate-200 rounded-3xl p-8 hover:bg-slate-900 hover:text-white group transition-colors duration-300 cursor-default shadow-sm hover:shadow-xl">
					<div class="w-14 h-14 rounded-2xl bg-slate-50 border border-slate-100 text-slate-700 flex items-center justify-center mb-6 group-hover:bg-white/10 group-hover:border-white/20 group-hover:text-white transition-all duration-300 group-hover:scale-110">
						<Sparkles class="w-7 h-7" />
					</div>
					<h3 class="text-xl font-bold text-slate-900 group-hover:text-white mb-3 transition-colors">Quality Care</h3>
					<p class="text-slate-600 group-hover:text-slate-300 text-sm leading-relaxed transition-colors">
						We partner exclusively with dedicated local vendors who take immense pride in their craft.
					</p>
				</div>

				<!-- Value 4 -->
				<div class="bg-white border border-slate-200 rounded-3xl p-8 hover:bg-slate-900 hover:text-white group transition-colors duration-300 cursor-default shadow-sm hover:shadow-xl">
					<div class="w-14 h-14 rounded-2xl bg-slate-50 border border-slate-100 text-slate-700 flex items-center justify-center mb-6 group-hover:bg-white/10 group-hover:border-white/20 group-hover:text-white transition-all duration-300 group-hover:scale-110">
						<Heart class="w-7 h-7" />
					</div>
					<h3 class="text-xl font-bold text-slate-900 group-hover:text-white mb-3 transition-colors">Empowerment</h3>
					<p class="text-slate-600 group-hover:text-slate-300 text-sm leading-relaxed transition-colors">
						Providing shop owners with digital tools to modernize their operations and boost income.
					</p>
				</div>
			</div>
		</div>
	</section>
