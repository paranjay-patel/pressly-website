---
---
	<!-- Timeline Section: Interactive Scroll style -->
	<section class="py-24 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6">
			<div class="text-center mb-20">
				<h2 class="font-display text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight">Company Timeline</h2>
			</div>

			<div class="relative">
				<!-- Vertical Line -->
				<div class="absolute left-8 md:left-1/2 md:-translate-x-1/2 top-0 bottom-0 w-1 bg-slate-100 rounded-full"></div>

				<div class="space-y-16">
					<!-- Phase 1 -->
					<div class="relative flex items-center justify-between md:justify-normal w-full group">
						<div class="hidden md:block w-1/2 pr-16 text-right">
							<h3 class="text-2xl font-bold text-slate-900 mb-2 group-hover:text-primary transition-colors">The Concept</h3>
							<p class="text-slate-600 leading-relaxed">Identifying the core problem in the local ironing ecosystem—lack of transparency—and designing the blueprint.</p>
						</div>
						<div class="absolute left-8 md:left-1/2 -translate-x-1/2 w-8 h-8 rounded-full bg-white border-4 border-slate-200 group-hover:border-primary group-hover:scale-125 transition-all duration-300 z-10 shadow-sm"></div>
						<div class="md:hidden pl-20 w-full">
							<span class="inline-block px-3 py-1 bg-slate-100 text-slate-700 text-xs font-bold rounded-lg mb-2">Phase 1</span>
							<h3 class="text-xl font-bold text-slate-900 mb-2">The Concept</h3>
							<p class="text-slate-600 text-sm leading-relaxed">Identifying the core problem in the local ironing ecosystem and designing the blueprint.</p>
						</div>
						<div class="hidden md:flex w-1/2 pl-16 items-center">
							<span class="inline-block px-4 py-2 bg-slate-50 border border-slate-200 text-slate-700 font-bold rounded-xl shadow-sm group-hover:-translate-y-1 transition-transform">Phase 1</span>
						</div>
					</div>

					<!-- Phase 2 -->
					<div class="relative flex items-center justify-between md:justify-normal md:flex-row-reverse w-full group">
						<div class="hidden md:block w-1/2 pl-16 text-left">
							<h3 class="text-2xl font-bold text-slate-900 mb-2 group-hover:text-primary transition-colors">Platform Development</h3>
							<p class="text-slate-600 leading-relaxed">Architecting the backend infrastructure, vendor applications, and customer-facing mobile apps for live tracking.</p>
						</div>
						<div class="absolute left-8 md:left-1/2 -translate-x-1/2 w-8 h-8 rounded-full bg-white border-4 border-slate-200 group-hover:border-primary group-hover:scale-125 transition-all duration-300 z-10 shadow-sm"></div>
						<div class="md:hidden pl-20 w-full">
							<span class="inline-block px-3 py-1 bg-slate-100 text-slate-700 text-xs font-bold rounded-lg mb-2">Phase 2</span>
							<h3 class="text-xl font-bold text-slate-900 mb-2">Platform Development</h3>
							<p class="text-slate-600 text-sm leading-relaxed">Architecting the backend infrastructure, vendor applications, and customer-facing mobile apps.</p>
						</div>
						<div class="hidden md:flex w-1/2 pr-16 items-center justify-end">
							<span class="inline-block px-4 py-2 bg-slate-50 border border-slate-200 text-slate-700 font-bold rounded-xl shadow-sm group-hover:-translate-y-1 transition-transform">Phase 2</span>
						</div>
					</div>

					<!-- Phase 3 -->
					<div class="relative flex items-center justify-between md:justify-normal w-full group">
						<div class="hidden md:block w-1/2 pr-16 text-right">
							<h3 class="text-2xl font-bold text-slate-900 mb-2 group-hover:text-primary transition-colors">Beta Launch</h3>
							<p class="text-slate-600 leading-relaxed">Rolling out the MVP in select neighborhoods in Surat. Partnering with local vendors to pilot the transformation.</p>
						</div>
						<div class="absolute left-8 md:left-1/2 -translate-x-1/2 w-8 h-8 rounded-full bg-primary border-4 border-white group-hover:scale-125 transition-all duration-300 z-10 shadow-md">
							<span class="absolute inset-0 rounded-full bg-primary animate-ping opacity-20"></span>
						</div>
						<div class="md:hidden pl-20 w-full">
							<span class="inline-block px-3 py-1 bg-primary text-white text-xs font-bold rounded-lg mb-2">Current</span>
							<h3 class="text-xl font-bold text-slate-900 mb-2">Beta Launch</h3>
							<p class="text-slate-600 text-sm leading-relaxed">Rolling out the MVP in select neighborhoods in Surat. Partnering with local vendors.</p>
						</div>
						<div class="hidden md:flex w-1/2 pl-16 items-center">
							<span class="inline-block px-4 py-2 bg-primary text-white font-bold rounded-xl shadow-md shadow-primary/20 group-hover:-translate-y-1 transition-transform">Current</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
