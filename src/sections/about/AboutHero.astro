---
---
	<!-- Hero Section: Interactive & Floating -->
	<section class="relative pt-24 pb-20 lg:pt-32 lg:pb-32 overflow-hidden bg-white group">
		<div class="absolute inset-0 bg-[linear-gradient(to_right,#f1f5f9_1px,transparent_1px),linear-gradient(to_bottom,#f1f5f9_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-60"></div>
		
		<div class="max-w-5xl mx-auto px-4 sm:px-6 text-center relative z-10">
			<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-50 border border-slate-200 text-slate-800 font-bold text-xs uppercase tracking-widest mb-8 hover:scale-105 transition-transform duration-300 shadow-sm cursor-default">
				<span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span> Our Story
			</div>
			<h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-extrabold text-slate-900 tracking-tight leading-[1.1] mb-8 transition-all duration-500">
				Organizing the <br class="hidden md:block"/> unorganized <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-sky-500 to-primary bg-[length:200%_auto] animate-[gradient_4s_linear_infinite]">ironing sector.</span>
			</h1>
			<p class="text-xl md:text-2xl text-slate-600 leading-relaxed max-w-3xl mx-auto font-medium">
				We are building the digital infrastructure to bring transparency, trust, and effortless convenience to everyday laundry needs.
			</p>
		</div>
		
		<!-- Floating Decorative Orbs -->
		<div class="absolute top-1/3 left-10 w-32 h-32 bg-sky-200 rounded-full mix-blend-multiply filter blur-2xl opacity-50 animate-[float_6s_ease-in-out_infinite]"></div>
		<div class="absolute top-1/4 right-10 w-32 h-32 bg-primary/20 rounded-full mix-blend-multiply filter blur-2xl opacity-50 animate-[float_6s_ease-in-out_infinite_2s]"></div>
	</section>
