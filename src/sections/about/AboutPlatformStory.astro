---
import { AlertCircle, Lightbulb, CheckCircle2 } from '@lucide/astro';
---

<section class="py-24 lg:py-32 bg-white relative">
	<div class="max-w-7xl mx-auto px-6">
		<div class="text-center max-w-4xl mx-auto mb-24">
			<h2 class="font-display text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-8">Why Pressly exists.</h2>
			<p class="text-2xl md:text-3xl text-slate-600 leading-snug font-medium italic">"We realized that by building a digital bridge between households and local vendors, we could solve everyday frustrations."</p>
		</div>
		
		<div class="grid md:grid-cols-3 gap-8">
			<!-- Step 1: Red (Rose) Accent & Glow -->
			<div class="bg-white p-10 rounded-[2.5rem] border border-slate-200/60 relative overflow-hidden group hover:-translate-y-2 hover:border-rose-200 hover:shadow-[0_20px_40px_-15px_rgba(244,63,94,0.15)] transition-all duration-300">
				<!-- Top Accent Line -->
				<div class="absolute top-0 left-0 right-0 h-1.5 bg-rose-500"></div>
				<div class="absolute -right-8 -bottom-10 text-[12rem] font-display font-extrabold text-slate-100 group-hover:text-rose-100/50 transition-colors pointer-events-none select-none">1</div>
				<div class="relative z-10">
					<!-- Icon -->
					<div class="w-12 h-12 rounded-2xl bg-rose-50 text-rose-500 flex items-center justify-center mb-8">
						<AlertCircle class="w-6 h-6" />
					</div>
					<h4 class="text-2xl font-bold text-slate-900 mb-4">The Broken System</h4>
					<p class="text-slate-600 text-lg leading-relaxed">Verbal counts, scribbled paper receipts, and zero visibility into delivery times. Trust diminishes over time.</p>
				</div>
			</div>
			
			<!-- Step 2: Yellow (Amber) Accent & Glow -->
			<div class="bg-white p-10 rounded-[2.5rem] border border-slate-200/60 relative overflow-hidden group hover:-translate-y-2 hover:border-amber-200 hover:shadow-[0_20px_40px_-15px_rgba(245,158,11,0.15)] transition-all duration-300">
				<!-- Top Accent Line -->
				<div class="absolute top-0 left-0 right-0 h-1.5 bg-amber-500"></div>
				<div class="absolute -right-8 -bottom-10 text-[12rem] font-display font-extrabold text-slate-100 group-hover:text-amber-100/50 transition-colors pointer-events-none select-none">2</div>
				<div class="relative z-10">
					<!-- Icon -->
					<div class="w-12 h-12 rounded-2xl bg-amber-50 text-amber-500 flex items-center justify-center mb-8">
						<Lightbulb class="w-6 h-6" />
					</div>
					<h4 class="text-2xl font-bold text-slate-900 mb-4">The Realization</h4>
					<p class="text-slate-600 text-lg leading-relaxed">A digital bridge connecting the customer and vendor could completely eliminate counting disputes.</p>
				</div>
			</div>

			<!-- Step 3: Green (Emerald) Accent & Glow -->
			<div class="bg-white p-10 rounded-[2.5rem] border border-slate-200/60 relative overflow-hidden group hover:-translate-y-2 hover:border-emerald-200 hover:shadow-[0_20px_40px_-15px_rgba(16,185,129,0.15)] transition-all duration-300">
				<!-- Top Accent Line -->
				<div class="absolute top-0 left-0 right-0 h-1.5 bg-emerald-500"></div>
				<div class="absolute -right-8 -bottom-10 text-[12rem] font-display font-extrabold text-slate-100 group-hover:text-emerald-100/50 transition-colors pointer-events-none select-none">3</div>
				<div class="relative z-10">
					<!-- Icon -->
					<div class="w-12 h-12 rounded-2xl bg-emerald-50 text-emerald-500 flex items-center justify-center mb-8">
						<CheckCircle2 class="w-6 h-6" />
					</div>
					<h4 class="text-2xl font-bold text-slate-900 mb-4">The Solution</h4>
					<p class="text-slate-600 text-lg leading-relaxed">Doorstep counting and live tracking for the customer, powered by a smart digital dashboard for the vendor.</p>
				</div>
			</div>
		</div>
	</div>
</section>
