---
---
	<!-- Registration Form Section -->
	<section class="py-20 bg-slate-50 border-t border-b border-slate-200" id="register">
		<div class="max-w-3xl mx-auto px-4 sm:px-6">
			<div class="text-center mb-12">
				<span class="inline-block px-4 py-1.5 rounded-full bg-white border border-slate-200 text-slate-700 font-bold text-sm mb-4">Application Form</span>
				<h2 class="font-display text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight mb-4">Apply as a Pressly Partner</h2>
				<p class="text-slate-600">Register your shop below to start receiving orders. It only takes 3 minutes.</p>
			</div>

			<!-- Success State -->
			<div id="success-state" class="hidden bg-white border border-slate-200 rounded-3xl p-10 text-center shadow-2xl">
				<div class="text-6xl mb-6">🎉</div>
				<h3 class="font-display text-2xl font-bold text-slate-900 mb-4">Application Submitted!</h3>
				<p class="text-slate-600 mb-6">Our Surat operations team is reviewing your application for <strong id="success-shop-name" class="text-slate-900"></strong>.</p>
				<div class="inline-block bg-amber-50 text-amber-700 font-bold text-sm px-6 py-2.5 rounded-full border border-amber-200/50 mb-6">
					Status: PENDING APPROVAL (Within 24 Hours)
				</div>
				<p class="text-xs text-slate-400 max-w-sm mx-auto">We will contact you via SMS as soon as your account is activated. Thank you!</p>
			</div>

			<!-- Error State -->
			<div id="error-state" class="hidden bg-red-50 border border-red-200 text-red-800 px-5 py-4 rounded-2xl flex items-center gap-3 mb-8 font-medium">
				<span class="text-xl">⚠️</span>
				<span id="error-msg">Something went wrong. Please try again.</span>
			</div>

			<!-- Form -->
			<form id="partner-form" class="flex flex-col gap-6">
				<!-- Step 1: Basic Details -->
				<div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
					<div class="flex items-center gap-4 mb-6 pb-4 border-b border-slate-100">
						<div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm">1</div>
						<h3 class="font-display font-bold text-slate-900 text-lg">Basic Details</h3>
					</div>
					<div class="grid md:grid-cols-2 gap-6">
						<div class="flex flex-col gap-2">
							<label for="shopName" class="text-sm font-semibold text-slate-600">Shop Name</label>
							<input type="text" id="shopName" name="shopName" required placeholder="e.g. Sai Laundry" class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 focus:outline-none focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10 transition-all placeholder:text-slate-400" />
						</div>
						<div class="flex flex-col gap-2">
							<label for="ownerName" class="text-sm font-semibold text-slate-600">Owner's Full Name</label>
							<input type="text" id="ownerName" name="ownerName" required placeholder="John Doe" class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 focus:outline-none focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10 transition-all placeholder:text-slate-400" />
						</div>
						<div class="flex flex-col gap-2 md:col-span-2">
							<label for="phone" class="text-sm font-semibold text-slate-600">Mobile Number</label>
							<div class="flex border border-slate-200 rounded-xl overflow-hidden bg-slate-50 focus-within:border-primary focus-within:bg-white focus-within:ring-4 focus-within:ring-primary/10 transition-all">
								<span class="px-4 py-3 bg-slate-100 border-r border-slate-200 text-slate-600 font-semibold">+91</span>
								<input type="tel" id="phone" name="phone" required pattern="[0-9]{10}" placeholder="9876543210" class="flex-1 px-4 py-3 border-none bg-transparent focus:outline-none text-slate-900 placeholder:text-slate-400" />
							</div>
						</div>
					</div>
				</div>

				<!-- Step 2: Location & Service -->
				<div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
					<div class="flex items-center gap-4 mb-6 pb-4 border-b border-slate-100">
						<div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm">2</div>
						<h3 class="font-display font-bold text-slate-900 text-lg">Location & Service Area</h3>
					</div>
					
					<div class="flex flex-col gap-2 mb-6">
						<label for="shopAddress" class="text-sm font-semibold text-slate-600">Full Shop Address</label>
						<textarea id="shopAddress" name="shopAddress" rows="2" required placeholder="Shop 12, Ring Road, Surat" class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 focus:outline-none focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10 transition-all placeholder:text-slate-400"></textarea>
					</div>

					<div class="flex flex-col sm:flex-row justify-between items-center bg-slate-50 p-6 rounded-2xl border border-dashed border-primary gap-4">
						<div class="text-center sm:text-left">
							<h4 class="font-bold text-slate-900 text-sm">Pinpoint your shop</h4>
							<p class="text-xs text-slate-600 mt-1">We use this to show your shop to nearby customers on the map.</p>
						</div>
						<button type="button" id="detect-btn" class="w-full sm:w-auto inline-flex items-center justify-center px-4 py-2.5 rounded-xl font-semibold text-sm bg-white text-slate-900 border border-slate-200 shadow-sm hover:bg-slate-100 transition-all shrink-0">📍 Detect My Location</button>
					</div>
					
					<div class="grid md:grid-cols-3 gap-6 mt-6">
						<div class="flex flex-col gap-2">
							<label for="latitude" class="text-sm font-semibold text-slate-600">Latitude</label>
							<input type="number" id="latitude" name="latitude" step="any" required placeholder="21.1702" class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 focus:outline-none focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10 transition-all placeholder:text-slate-400" />
						</div>
						<div class="flex flex-col gap-2">
							<label for="longitude" class="text-sm font-semibold text-slate-600">Longitude</label>
							<input type="number" id="longitude" name="longitude" step="any" required placeholder="72.8311" class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 focus:outline-none focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10 transition-all placeholder:text-slate-400" />
						</div>
						<div class="flex flex-col gap-2">
							<label for="serviceRadiusKm" class="text-sm font-semibold text-slate-600">Service Radius</label>
							<select id="serviceRadiusKm" name="serviceRadiusKm" required class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 focus:outline-none focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10 transition-all">
								<option value="1">1 km</option>
								<option value="2" selected>2 km (Recommended)</option>
								<option value="3">3 km</option>
								<option value="5">5 km</option>
							</select>
						</div>
					</div>
				</div>

				<!-- Step 3: Operating Hours -->
				<div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
					<div class="flex items-center gap-4 mb-6 pb-4 border-b border-slate-100">
						<div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm">3</div>
						<h3 class="font-display font-bold text-slate-900 text-lg">Operating Hours</h3>
					</div>
					<div class="grid md:grid-cols-2 gap-6">
						<div class="flex flex-col gap-2">
							<label for="openingTime" class="text-sm font-semibold text-slate-600">Opening Time</label>
							<input type="text" id="openingTime" name="openingTime" required placeholder="09:00 AM" class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 focus:outline-none focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10 transition-all placeholder:text-slate-400" />
						</div>
						<div class="flex flex-col gap-2">
							<label for="closingTime" class="text-sm font-semibold text-slate-600">Closing Time</label>
							<input type="text" id="closingTime" name="closingTime" required placeholder="08:00 PM" class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 text-slate-900 focus:outline-none focus:border-primary focus:bg-white focus:ring-4 focus:ring-primary/10 transition-all placeholder:text-slate-400" />
						</div>
					</div>
				</div>

				<button type="submit" id="submit-btn" class="w-full py-4 rounded-2xl font-semibold text-lg bg-slate-900 text-white shadow-sm hover:bg-slate-800 hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2">
					Submit Application
				</button>
			</form>
		</div>
	</section>

	<script>
		// Geolocation Logic
		const detectBtn = document.getElementById('detect-btn');
		const latInput = document.getElementById('latitude') as HTMLInputElement;
		const lngInput = document.getElementById('longitude') as HTMLInputElement;

		detectBtn?.addEventListener('click', () => {
			if (!navigator.geolocation) {
				alert('Geolocation not supported by your browser.');
				return;
			}
			
			detectBtn.innerHTML = '<span class="inline-block w-4 h-4 border-2 border-slate-900 border-t-transparent rounded-full animate-spin mr-2"></span> Detecting...';
			
			navigator.geolocation.getCurrentPosition(
				(pos) => {
					latInput.value = pos.coords.latitude.toFixed(6);
					lngInput.value = pos.coords.longitude.toFixed(6);
					detectBtn.innerHTML = '✅ Location Saved';
					detectBtn.classList.remove('bg-white', 'text-slate-900', 'border-slate-200', 'hover:bg-slate-100');
					detectBtn.classList.add('bg-emerald-500', 'text-white', 'border-emerald-500', 'hover:bg-emerald-600');
				},
				(err) => {
					console.error(err);
					alert('Could not detect location. Defaulting to Surat center.');
					latInput.value = "21.170244";
					lngInput.value = "72.831061";
					detectBtn.innerHTML = '📍 Loaded Default';
				},
				{ enableHighAccuracy: true }
			);
		});

		// Form Submission Logic
		const form = document.getElementById('partner-form') as HTMLFormElement;
		const successState = document.getElementById('success-state');
		const errorState = document.getElementById('error-state');
		const errorMsg = document.getElementById('error-msg');
		const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
		const successShopName = document.getElementById('success-shop-name');

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			errorState?.classList.add('hidden');
			submitBtn.disabled = true;
			submitBtn.innerHTML = '<span class="inline-block w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin mr-2"></span> Submitting...';

			const formData = new FormData(form);
			const payload = {
				phone: "+91" + formData.get('phone'),
				ownerName: formData.get('ownerName'),
				shopName: formData.get('shopName'),
				shopAddress: formData.get('shopAddress'),
				latitude: parseFloat(formData.get('latitude') as string),
				longitude: parseFloat(formData.get('longitude') as string),
				serviceRadiusKm: parseInt(formData.get('serviceRadiusKm') as string),
				openingTime: formData.get('openingTime'),
				closingTime: formData.get('closingTime'),
			};

			try {
				const response = await fetch('http://localhost:4000/api/v1/auth/vendor-register', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(payload),
				});

				const result = await response.json();

				if (!response.ok) {
					throw new Error(result.message || 'Submission failed');
				}

				if (successShopName) successShopName.textContent = payload.shopName as string;
				form.classList.add('hidden');
				successState?.classList.remove('hidden');
				
				// Track custom event
				if (typeof window.trackEvent === 'function') {
					window.trackEvent('vendor_form_submit', { shopName: payload.shopName });
				}
				
				window.scrollTo({ top: document.getElementById('register')?.offsetTop! - 100, behavior: 'smooth' });

			} catch (err: any) {
				console.error(err);
				if (errorMsg) errorMsg.textContent = err.message || 'Server error. Try again.';
				errorState?.classList.remove('hidden');
				submitBtn.disabled = false;
				submitBtn.innerHTML = 'Submit Application';
			}
		});
	</script>
