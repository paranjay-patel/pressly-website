---
import { TrendingUp, ShieldCheck, IndianRupee } from '@lucide/astro';
---

	<!-- Benefits Section -->
	<section class="py-20 bg-slate-50 border-t border-b border-slate-200">
		<div class="max-w-7xl mx-auto px-4 sm:px-6">
			<div class="text-center max-w-3xl mx-auto mb-16">
				<span class="inline-block px-4 py-1.5 rounded-full bg-white border border-slate-200 text-primary font-bold text-sm mb-4">Why Partner With Us</span>
				<h2 class="font-display text-3xl md:text-5xl font-extrabold text-slate-900 tracking-tight">Built to scale your shop operations</h2>
			</div>

			<div class="grid md:grid-cols-3 gap-8">
				<!-- Benefit 1 -->
				<div class="bg-white rounded-3xl border border-slate-200 p-8 hover:shadow-md transition-all duration-300">
					<div class="w-12 h-12 rounded-2xl bg-sky-50 text-primary flex items-center justify-center mb-6">
						<TrendingUp class="w-6 h-6" />
					</div>
					<h3 class="text-xl font-bold text-slate-900 mb-3">Guaranteed Order Volume</h3>
					<p class="text-slate-600 leading-relaxed">
						Gain instant exposure to hundreds of households in your designated 2km service radius. Say goodbye to slow business days.
					</p>
				</div>

				<!-- Benefit 2 -->
				<div class="bg-white rounded-3xl border border-slate-200 p-8 hover:shadow-md transition-all duration-300">
					<div class="w-12 h-12 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center mb-6">
						<ShieldCheck class="w-6 h-6" />
					</div>
					<h3 class="text-xl font-bold text-slate-900 mb-3">Zero Counting Disputes</h3>
					<p class="text-slate-600 leading-relaxed">
						Lock in exact item counts and cloth conditions with customers right at their doorstep using the Pressly app. Fully transparent.
					</p>
				</div>

				<!-- Benefit 3 -->
				<div class="bg-white rounded-3xl border border-slate-200 p-8 hover:shadow-md transition-all duration-300">
					<div class="w-12 h-12 rounded-2xl bg-amber-50 text-amber-600 flex items-center justify-center mb-6">
						<IndianRupee class="w-6 h-6" />
					</div>
					<h3 class="text-xl font-bold text-slate-900 mb-3">Weekly Direct Payouts</h3>
					<p class="text-slate-600 leading-relaxed">
						Receive your hard-earned payouts directly to your bank account every single week. Monitor all transactions in your app.
					</p>
				</div>
			</div>
		</div>
	</section>
