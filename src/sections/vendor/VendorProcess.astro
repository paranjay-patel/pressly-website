---
---
	<!-- Process Section -->
	<section class="py-20 bg-white">
		<div class="max-w-7xl mx-auto px-4 sm:px-6">
			<div class="text-center max-w-3xl mx-auto mb-16">
				<span class="inline-block px-4 py-1.5 rounded-full bg-slate-100 border border-slate-200 text-primary font-bold text-sm mb-4">How it works</span>
				<h2 class="font-display text-3xl md:text-5xl font-extrabold text-slate-900 tracking-tight">4 Simple Steps to Success</h2>
			</div>

			<div class="grid md:grid-cols-4 gap-8 relative">
				<!-- Step 1 -->
				<div class="flex flex-col items-center text-center">
					<div class="w-16 h-16 rounded-full bg-slate-100 border-2 border-slate-200 flex items-center justify-center font-display font-extrabold text-xl text-slate-900 mb-6">
						1
					</div>
					<h3 class="text-lg font-bold text-slate-900 mb-2">Register Online</h3>
					<p class="text-sm text-slate-600 leading-relaxed">
						Fill out the basic shop details and submit your pricing catalog.
					</p>
				</div>

				<!-- Step 2 -->
				<div class="flex flex-col items-center text-center">
					<div class="w-16 h-16 rounded-full bg-slate-100 border-2 border-slate-200 flex items-center justify-center font-display font-extrabold text-xl text-slate-900 mb-6">
						2
					</div>
					<h3 class="text-lg font-bold text-slate-900 mb-2">Get Approved</h3>
					<p class="text-sm text-slate-600 leading-relaxed">
						Our local operations team will verify your shop within 24 hours.
					</p>
				</div>

				<!-- Step 3 -->
				<div class="flex flex-col items-center text-center">
					<div class="w-16 h-16 rounded-full bg-slate-100 border-2 border-slate-200 flex items-center justify-center font-display font-extrabold text-xl text-slate-900 mb-6">
						3
					</div>
					<h3 class="text-lg font-bold text-slate-900 mb-2">Accept Orders</h3>
					<p class="text-sm text-slate-600 leading-relaxed">
						Receive nearby delivery requests and count the clothes at customer doorsteps.
					</p>
				</div>

				<!-- Step 4 -->
				<div class="flex flex-col items-center text-center">
					<div class="w-16 h-16 rounded-full bg-primary text-white border-2 border-primary flex items-center justify-center font-display font-extrabold text-xl mb-6 shadow-md shadow-primary/20">
						4
					</div>
					<h3 class="text-lg font-bold text-slate-900 mb-2">Deliver & Get Paid</h3>
					<p class="text-sm text-slate-600 leading-relaxed">
						Iron, package, and deliver clothes. Receive weekly payouts directly to your account.
					</p>
				</div>
			</div>
		</div>
	</section>
