---
import { MapPin, ListOrdered, Truck } from '@lucide/astro';
---

<!-- 3. Why Choose Us (Bento Grid) -->
	<section id="why-choose-us" class="py-32 bg-white">
		<div class="max-w-7xl mx-auto px-6">
			<div class="text-center max-w-2xl mx-auto mb-20">
				<span class="inline-block px-4 py-1.5 rounded-full bg-slate-100 text-primary font-semibold text-sm mb-4 border border-slate-200">Why Choose Us</span>
				<h2 class="font-display text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-6">The End of Laundry Disputes</h2>
				<p class="text-lg text-slate-600">We solved the biggest pain points of local ironing services by introducing technology where it matters most.</p>
			</div>
			
			<div class="grid md:grid-cols-3 gap-6 auto-rows-[300px]">
				<!-- Feature 1: Geo Discovery (Spans 2 columns on tablet+) -->
				<div class="md:col-span-2 group relative overflow-hidden rounded-[2rem] bg-white/40 backdrop-blur-md border border-slate-200 p-10 hover:border-primary/50 transition-all duration-300 hover:shadow-xl hover:shadow-sky-100/30">
					<div class="absolute top-0 right-0 w-32 h-32 bg-sky-200/60 rounded-full blur-2xl -mr-10 -mt-10 opacity-50 animate-blob pointer-events-none"></div>
					<div class="relative z-10 flex flex-col h-full">
						<div class="w-14 h-14 rounded-2xl bg-white/60 backdrop-blur-sm shadow-sm border border-white flex items-center justify-center mb-6"><MapPin class="w-7 h-7 text-primary" /></div>
						<h3 class="font-display text-2xl font-bold text-slate-900 mb-3">Geo-Discovery</h3>
						<p class="text-slate-600 leading-relaxed max-w-md">Find the best local vendors near your house. Compare prices, check their ratings, and book instantly without making a single phone call.</p>
					</div>
				</div>

				<!-- Feature 2: Doorstep Counting -->
				<div class="group relative overflow-hidden rounded-[2rem] bg-white/40 backdrop-blur-md border border-slate-200 p-10 hover:border-primary/50 transition-all duration-300 hover:shadow-xl hover:shadow-sky-100/30">
					<div class="absolute bottom-0 right-0 w-32 h-32 bg-primary/20 rounded-full blur-2xl -mr-10 -mb-10 opacity-50 animate-blob pointer-events-none"></div>
					<div class="relative z-10 flex flex-col h-full">
						<div class="w-14 h-14 rounded-2xl bg-white/60 backdrop-blur-sm shadow-sm border border-white flex items-center justify-center mb-6"><ListOrdered class="w-7 h-7 text-primary" /></div>
						<h3 class="font-display text-2xl font-bold text-slate-900 mb-3">Doorstep Counting</h3>
						<p class="text-slate-600 leading-relaxed">Stop worrying about missing clothes. The vendor physically counts items at your door.</p>
					</div>
				</div>

				<!-- Feature 3: Live Order Tracking (Spans full width) -->
				<div class="md:col-span-3 group relative overflow-hidden rounded-[2rem] bg-slate-900 border border-slate-800 p-10 flex flex-col md:flex-row items-center gap-10">
					<div class="absolute inset-0 bg-primary/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
					<div class="relative z-10 flex-1">
						<div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center mb-6 backdrop-blur-md"><Truck class="w-7 h-7 text-white" /></div>
						<h3 class="font-display text-3xl font-bold text-white mb-4">Live Order Tracking</h3>
						<p class="text-slate-300 text-lg leading-relaxed max-w-2xl">From the moment clothes leave your hands to the moment they return crisp and fresh, track every step in real-time on your phone. No more guessing when your clothes will arrive.</p>
					</div>
					<div class="hidden md:flex relative z-10 w-full max-w-sm bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
						<!-- Mini timeline UI -->
						<div class="flex flex-col gap-6 w-full">
							<div class="flex items-center gap-4"><div class="w-4 h-4 rounded-full bg-emerald-400"></div><div class="h-2 bg-white/20 rounded-full flex-1"></div></div>
							<div class="flex items-center gap-4"><div class="w-4 h-4 rounded-full bg-emerald-400"></div><div class="h-2 bg-white/20 rounded-full flex-1"></div></div>
							<div class="flex items-center gap-4"><div class="w-4 h-4 rounded-full bg-primary shadow-[0_0_15px_rgba(2,132,199,0.5)]"></div><div class="h-2 w-1/2 bg-white/20 rounded-full"></div></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
