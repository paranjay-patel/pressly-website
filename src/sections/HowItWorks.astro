								</div>
							</div>
						</div>

						<button class="w-full py-3.5 rounded-xl font-bold text-sm bg-slate-900 text-white hover:bg-slate-800 transition-all flex items-center justify-center gap-2 shadow-sm">
							Confirm Pickup Slot <ArrowRight class="w-4 h-4" />
						</button>
					</div>

					<!-- Screen 3: Vendor Collects -->
					<div id="step-screen-3" class="absolute inset-0 flex flex-col justify-between transition-all duration-500 ease-out opacity-0 scale-95 pointer-events-none">
						<div>
							<h3 class="font-display font-bold text-lg text-slate-900 mb-1">Verify Counter</h3>
							<p class="text-xs text-slate-500 mb-4">Confirm clothes counted at your doorstep</p>
							
							<!-- Digital Receipt UI (Solid) -->
							<div class="bg-slate-50 rounded-xl border border-slate-200 p-4 space-y-3.5">
								<div class="flex justify-between items-center text-xs">
									<span class="text-slate-500">Shirts (5)</span>
									<span class="font-bold text-slate-900">₹100</span>
								</div>
								<div class="flex justify-between items-center text-xs">
									<span class="text-slate-500">Pants (2)</span>
