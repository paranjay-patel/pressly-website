							</div>
						</div>

						<button class="w-full py-3.5 rounded-xl font-bold text-sm bg-slate-900 text-white hover:bg-slate-800 transition-all flex items-center justify-center gap-2 shadow-sm">
							Pay via Razorpay
						</button>
					</div>

					<!-- Screen 4: Receive Clothes -->
					<div id="step-screen-4" class="absolute inset-0 flex flex-col justify-between transition-all duration-500 ease-out opacity-0 scale-95 pointer-events-none">
						<div class="flex-1 flex flex-col items-center justify-center text-center px-4">
							<!-- Animated Check Circle -->
							<div class="w-16 h-16 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 mb-4 shadow-sm border border-emerald-200">
								<Check class="w-8 h-8" />
							</div>
							<h3 class="font-display font-bold text-xl text-slate-900 mb-2">Delivered & Pressed!</h3>
							<p class="text-sm text-slate-500 mb-6">Your clothes are returned perfectly pressed and ready to wear.</p>
							
							<!-- Rating stars -->
							<div class="flex gap-1.5 mb-2">
								<Star class="w-5 h-5 fill-amber-400 text-amber-400" />
								<Star class="w-5 h-5 fill-amber-400 text-amber-400" />
								<Star class="w-5 h-5 fill-amber-400 text-amber-400" />
								<Star class="w-5 h-5 fill-amber-400 text-amber-400" />
								<Star class="w-5 h-5 fill-amber-400 text-amber-400" />
							</div>
							<span class="text-xs font-semibold text-slate-500">Rated 5.0 for Classic Dhobi</span>
						</div>

						<div class="p-3 bg-emerald-50 rounded-xl border border-emerald-100 text-center text-xs font-semibold text-emerald-700">
							✨ Wardrobe Hangers Returned
						</div>
					</div>

				</div>
			</div>
		</div>
		
		<!-- Right: Steps Timeline -->
		<div class="lg:pl-8 flex flex-col justify-center">
			<div>
				<span class="inline-block px-4 py-1.5 rounded-full bg-slate-100 text-slate-800 font-semibold text-sm mb-6 border border-slate-200 shadow-sm">How It Works</span>
				<h2 class="font-display text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-12">Four Steps to Perfection</h2>
			</div>
			
			<!-- Horizontal Progress Bar (Inspired by user design) -->
			<div class="relative flex items-center justify-between w-full mb-20 px-2 sm:px-4">
				<!-- Background Track -->
				<div class="absolute left-0 top-1/2 -translate-y-1/2 w-full h-1.5 bg-slate-200 rounded-full"></div>
				<!-- Active Progress Track -->
				<div id="horizontal-progress" class="absolute left-0 top-1/2 -translate-y-1/2 h-1.5 bg-slate-900 rounded-full transition-all duration-500 ease-out" style="width: 0%;"></div>

				<!-- Step 1 Indicator -->
				<button class="step-indicator group relative z-10 flex flex-col items-center cursor-pointer outline-none min-h-[44px] min-w-[44px]" data-index="0" data-state="active">
					<div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-sm sm:text-base transition-all duration-500 ring-[6px] ring-white
						group-data-[state=active]:bg-slate-900 group-data-[state=active]:text-white group-data-[state=active]:shadow-lg group-data-[state=active]:scale-110 
						group-data-[state=completed]:bg-slate-900 group-data-[state=completed]:text-white group-data-[state=completed]:shadow-md
						group-data-[state=inactive]:bg-slate-100 group-data-[state=inactive]:text-slate-400 group-data-[state=inactive]:border-2 group-data-[state=inactive]:border-slate-300 group-data-[state=inactive]:hover:bg-slate-200">
						
						<span class="group-data-[state=completed]:hidden">1</span>
						<svg class="hidden group-data-[state=completed]:block w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
							<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
						</svg>
					</div>
					<span class="absolute top-[3.5rem] sm:top-[4.25rem] text-[10px] sm:text-xs font-bold tracking-wider uppercase transition-colors duration-500
						group-data-[state=active]:text-slate-900 group-data-[state=completed]:text-slate-900 group-data-[state=inactive]:text-slate-400">
						Vendor
					</span>
				</button>

				<!-- Step 2 Indicator -->
				<button class="step-indicator group relative z-10 flex flex-col items-center cursor-pointer outline-none min-h-[44px] min-w-[44px]" data-index="1" data-state="inactive">
					<div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-sm sm:text-base transition-all duration-500 ring-[6px] ring-white
						group-data-[state=active]:bg-slate-900 group-data-[state=active]:text-white group-data-[state=active]:shadow-lg group-data-[state=active]:scale-110 
						group-data-[state=completed]:bg-slate-900 group-data-[state=completed]:text-white group-data-[state=completed]:shadow-md
						group-data-[state=inactive]:bg-slate-100 group-data-[state=inactive]:text-slate-400 group-data-[state=inactive]:border-2 group-data-[state=inactive]:border-slate-300 group-data-[state=inactive]:hover:bg-slate-200">
						
						<span class="group-data-[state=completed]:hidden">2</span>
						<svg class="hidden group-data-[state=completed]:block w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
							<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
						</svg>
					</div>
					<span class="absolute top-[3.5rem] sm:top-[4.25rem] text-[10px] sm:text-xs font-bold tracking-wider uppercase transition-colors duration-500
						group-data-[state=active]:text-slate-900 group-data-[state=completed]:text-slate-900 group-data-[state=inactive]:text-slate-400">
						Schedule
					</span>
				</button>

				<!-- Step 3 Indicator -->
				<button class="step-indicator group relative z-10 flex flex-col items-center cursor-pointer outline-none min-h-[44px] min-w-[44px]" data-index="2" data-state="inactive">
					<div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-sm sm:text-base transition-all duration-500 ring-[6px] ring-white
						group-data-[state=active]:bg-slate-900 group-data-[state=active]:text-white group-data-[state=active]:shadow-lg group-data-[state=active]:scale-110 
						group-data-[state=completed]:bg-slate-900 group-data-[state=completed]:text-white group-data-[state=completed]:shadow-md
						group-data-[state=inactive]:bg-slate-100 group-data-[state=inactive]:text-slate-400 group-data-[state=inactive]:border-2 group-data-[state=inactive]:border-slate-300 group-data-[state=inactive]:hover:bg-slate-200">
						
						<span class="group-data-[state=completed]:hidden">3</span>
						<svg class="hidden group-data-[state=completed]:block w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
							<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
						</svg>
					</div>
					<span class="absolute top-[3.5rem] sm:top-[4.25rem] text-[10px] sm:text-xs font-bold tracking-wider uppercase transition-colors duration-500
						group-data-[state=active]:text-slate-900 group-data-[state=completed]:text-slate-900 group-data-[state=inactive]:text-slate-400">
						Pickup
					</span>
				</button>

				<!-- Step 4 Indicator -->
				<button class="step-indicator group relative z-10 flex flex-col items-center cursor-pointer outline-none min-h-[44px] min-w-[44px]" data-index="3" data-state="inactive">
					<div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-sm sm:text-base transition-all duration-500 ring-[6px] ring-white
						group-data-[state=active]:bg-slate-900 group-data-[state=active]:text-white group-data-[state=active]:shadow-lg group-data-[state=active]:scale-110 
						group-data-[state=completed]:bg-slate-900 group-data-[state=completed]:text-white group-data-[state=completed]:shadow-md
						group-data-[state=inactive]:bg-slate-100 group-data-[state=inactive]:text-slate-400 group-data-[state=inactive]:border-2 group-data-[state=inactive]:border-slate-300 group-data-[state=inactive]:hover:bg-slate-200">
						
						<span class="group-data-[state=completed]:hidden">4</span>
						<svg class="hidden group-data-[state=completed]:block w-5 h-5 sm:w-6 sm:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
							<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
						</svg>
					</div>
					<span class="absolute top-[3.5rem] sm:top-[4.25rem] text-[10px] sm:text-xs font-bold tracking-wider uppercase transition-colors duration-500
						group-data-[state=active]:text-slate-900 group-data-[state=completed]:text-slate-900 group-data-[state=inactive]:text-slate-400">
						Delivery
					</span>
				</button>
			</div>

			<!-- Single Step Content Card (Zero Scrolling) -->
			<div class="relative w-full rounded-[2rem] border-2 border-slate-200 bg-white text-slate-900 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.1)] overflow-hidden">
				<!-- Background pattern for elegance -->
				<div class="absolute inset-0 opacity-40 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-slate-50 via-transparent to-transparent pointer-events-none"></div>

				<div class="relative z-10 w-full grid [grid-template-areas:'stack'] items-center min-h-[180px] sm:min-h-[160px]">
					<!-- Step 1 Content -->
					<div class="step-content [grid-area:stack] p-6 sm:p-8 flex flex-col justify-center transition-all duration-500 ease-out opacity-100 translate-x-0 pointer-events-auto" data-index="0">
						<h4 class="text-xl sm:text-2xl font-bold mb-3">Choose Vendor</h4>
						<p class="text-slate-600 leading-relaxed text-sm md:text-base pr-4">Select your preferred local vendor based on upfront rates, ratings, and distance.</p>
					</div>
					<!-- Step 2 Content -->
					<div class="step-content [grid-area:stack] p-6 sm:p-8 flex flex-col justify-center transition-all duration-500 ease-out opacity-0 translate-x-8 pointer-events-none" data-index="1">
						<h4 class="text-xl sm:text-2xl font-bold mb-3">Schedule Pickup</h4>
						<p class="text-slate-600 leading-relaxed text-sm md:text-base pr-4">Pick a date and convenient 1-hour time window that works best for your schedule.</p>
					</div>
					<!-- Step 3 Content -->
					<div class="step-content [grid-area:stack] p-6 sm:p-8 flex flex-col justify-center transition-all duration-500 ease-out opacity-0 translate-x-8 pointer-events-none" data-index="2">
						<h4 class="text-xl sm:text-2xl font-bold mb-3">Vendor Collects</h4>
						<p class="text-slate-600 leading-relaxed text-sm md:text-base pr-4">Vendor arrives, counts items at your doorstep, and locks the price in an instant digital receipt.</p>
					</div>
					<!-- Step 4 Content -->
					<div class="step-content [grid-area:stack] p-6 sm:p-8 flex flex-col justify-center transition-all duration-500 ease-out opacity-0 translate-x-8 pointer-events-none" data-index="3">
						<h4 class="text-xl sm:text-2xl font-bold mb-3">Receive Clothes</h4>
						<p class="text-slate-600 leading-relaxed text-sm md:text-base pr-4">Your freshly pressed clothes are returned on hangers, crisp and ready to wear.</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Client Interaction Script -->
<script>
	document.addEventListener('DOMContentLoaded', () => {
		const stepIndicators = document.querySelectorAll('.step-indicator');
		const stepContents = document.querySelectorAll('.step-content');
		const stepScreens = [
			document.getElementById('step-screen-1'),
			document.getElementById('step-screen-2'),
			document.getElementById('step-screen-3'),
			document.getElementById('step-screen-4')
		];
		const progressLine = document.getElementById('horizontal-progress');

		function activateStep(index) {
			// Update horizontal progress line (3 segments = 0%, 33.3%, 66.6%, 100%)
			if (progressLine) {
				const percentages = ['0%', '33.33%', '66.66%', '100%'];
				progressLine.style.width = percentages[index];
			}

			// Update Indicators
			stepIndicators.forEach((indicator, i) => {
				if (i < index) {
					indicator.setAttribute('data-state', 'completed');
				} else if (i === index) {
					indicator.setAttribute('data-state', 'active');
				} else {
					indicator.setAttribute('data-state', 'inactive');
				}
			});

			// Update Text Contents
			stepContents.forEach((content, i) => {
				if (i === index) {
					content.classList.remove('opacity-0', 'translate-x-8', '-translate-x-8', 'pointer-events-none');
					content.classList.add('opacity-100', 'translate-x-0', 'pointer-events-auto');
				} else if (i < index) {
					// Pushed left
					content.classList.remove('opacity-100', 'translate-x-0', 'translate-x-8', 'pointer-events-auto');
					content.classList.add('opacity-0', '-translate-x-8', 'pointer-events-none');
				} else {
					// Pushed right
					content.classList.remove('opacity-100', 'translate-x-0', '-translate-x-8', 'pointer-events-auto');
					content.classList.add('opacity-0', 'translate-x-8', 'pointer-events-none');
				}
			});

			// Update Phone Screens
			stepScreens.forEach((screen, i) => {
				if (!screen) return;
				if (i === index) {
					screen.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
					screen.classList.add('opacity-100', 'scale-100', 'pointer-events-auto');
				} else {
					screen.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto');
					screen.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
				}
			});
		}

		stepIndicators.forEach((btn, index) => {
			// Trigger on click
			btn.addEventListener('click', () => activateStep(index));
			// Optional: Trigger on hover for ultra-smooth desktop experience
			btn.addEventListener('mouseenter', () => activateStep(index));
		});
	});
</script>
