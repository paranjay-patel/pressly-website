---
import { Calendar, Check, Star, MapPin, Sparkles, Clock, ArrowRight, Store, UserCheck, Shield } from '@lucide/astro';
---

<section id="how-it-works" class="how-it-works-section py-24 bg-white relative overflow-hidden border-t border-slate-100">
    <!-- Subtle Background Elements -->
    <div class="absolute top-0 right-0 w-[40rem] h-[40rem] bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/4 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <!-- Left: Interactive Mobile Mockup -->
        <div class="order-2 lg:order-1 perspective-1000 relative">
            <!-- Full, Detailed App Mockup -->
            <div class="relative bg-white rounded-[2.5rem] shadow-2xl shadow-slate-200/50 border border-slate-200 w-full max-w-sm mx-auto h-[540px] p-6 flex flex-col justify-between overflow-hidden">
                <!-- Mock Status Bar -->
                <div class="flex justify-between items-center text-xs text-slate-500 font-bold mb-6 px-2">
                    <span>9:41</span>
                    <div class="flex gap-1.5 items-center">
                        <div class="w-3.5 h-2 bg-slate-500 rounded-sm"></div>
                    </div>
                </div>

                <!-- Screen Container -->
                <div class="relative flex-1 flex flex-col justify-between">
                    <!-- Screen 1: Choose Vendor -->
                    <div class="step-screen absolute inset-0 flex flex-col justify-between transition-all duration-500 ease-out opacity-100 scale-100 pointer-events-auto" data-index="0">
                        <div>
                            <h3 class="font-display font-bold text-xl text-slate-900 mb-1">Choose Vendor</h3>
                            <p class="text-sm text-slate-500 mb-5">Select your favorite local partner</p>
                            
                            <div class="space-y-3">
                                <!-- Selected Vendor -->
                                <div class="p-3.5 bg-slate-900 text-white rounded-2xl border border-slate-900 flex justify-between items-center shadow-lg shadow-slate-900/20">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-xl bg-slate-800 flex items-center justify-center text-white shrink-0">
                                            <Store class="w-5 h-5" />
                                        </div>
                                        <div class="text-left">
                                            <p class="text-sm font-bold">Classic Dhobi</p>
                                            <p class="text-[11px] text-slate-400">Fast delivery • 0.8 km</p>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <div class="flex items-center justify-end gap-1 text-[11px] font-bold text-amber-400 mb-0.5">
                                            <Star class="w-3.5 h-3.5 fill-amber-400 text-amber-400" /> 4.8
                                        </div>
                                        <p class="text-sm font-bold mt-0.5">₹12/item</p>
                                    </div>
                                </div>
                                
                                <!-- Alternative Vendor -->
                                <div class="p-3.5 bg-slate-50 rounded-2xl border border-slate-200 flex justify-between items-center hover:bg-white transition-colors cursor-pointer">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                            <Store class="w-5 h-5" />
                                        </div>
                                        <div class="text-left">
                                            <p class="text-sm font-bold text-slate-900">Express Ironing</p>
                                            <p class="text-[11px] text-slate-500">Premium care • 1.2 km</p>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <div class="flex items-center justify-end gap-1 text-[11px] font-bold text-amber-500 mb-0.5">
                                            <Star class="w-3.5 h-3.5 fill-amber-500 text-amber-500" /> 4.9
                                        </div>
                                        <p class="text-sm font-bold text-slate-900 mt-0.5">₹15/item</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <button class="w-full py-4 rounded-xl font-bold text-sm bg-slate-900 text-white hover:bg-slate-800 transition-all flex items-center justify-center gap-2 shadow-sm mt-4">
                            Select Classic Dhobi <ArrowRight class="w-4 h-4" />
                        </button>
                    </div>

                    <!-- Screen 2: Schedule Pickup -->
                    <div class="step-screen absolute inset-0 flex flex-col justify-between transition-all duration-500 ease-out opacity-0 scale-95 pointer-events-none" data-index="1">
                        <div>
                            <h3 class="font-display font-bold text-xl text-slate-900 mb-1">Select Pickup Slot</h3>
                            <p class="text-sm text-slate-500 mb-5">Choose a convenient time for doorstep pickup</p>
                            
                            <div class="grid grid-cols-2 gap-3 mb-5">
                                <div class="p-4 bg-slate-900 text-white rounded-2xl border border-slate-900 text-center shadow-lg shadow-slate-900/20">
                                    <p class="text-xs font-semibold text-slate-300">Today</p>
                                    <p class="text-base font-bold mt-1">4 PM - 5 PM</p>
                                </div>
                                <div class="p-4 bg-slate-50 rounded-2xl border border-slate-200 text-center hover:bg-white transition-colors cursor-pointer">
                                    <p class="text-xs text-slate-500 font-semibold">Tomorrow</p>
                                    <p class="text-base font-bold text-slate-900 mt-1">9 AM - 10 AM</p>
                                </div>
                            </div>
                            
                            <div class="p-4 bg-slate-50 rounded-2xl border border-slate-200 flex items-center gap-4">
                                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary shrink-0">
                                    <MapPin class="w-5 h-5" />
                                </div>
                                <div class="text-left overflow-hidden">
                                    <p class="text-sm font-bold text-slate-900">Pickup Location</p>
                                    <p class="text-xs text-slate-500 truncate w-full mt-0.5">Guiten Park, Vesu, Surat</p>
                                </div>
                            </div>
                        </div>
                        <button class="w-full py-4 rounded-xl font-bold text-sm bg-slate-900 text-white hover:bg-slate-800 transition-all flex items-center justify-center gap-2 shadow-sm mt-4">
                            Confirm Pickup Slot <ArrowRight class="w-4 h-4" />
                        </button>
                    </div>

                    <!-- Screen 3: Vendor Collects -->
                    <div class="step-screen absolute inset-0 flex flex-col justify-between transition-all duration-500 ease-out opacity-0 scale-95 pointer-events-none" data-index="2">
                        <div>
                            <h3 class="font-display font-bold text-xl text-slate-900 mb-1">Verify Counter</h3>
                            <p class="text-sm text-slate-500 mb-5">Confirm clothes counted at your doorstep</p>
                            
                            <div class="bg-slate-50 rounded-2xl border border-slate-200 p-5 space-y-4">
                                <div class="flex justify-between items-center text-sm">
                                    <span class="text-slate-600 font-medium">Shirts (5)</span>
                                    <span class="font-bold text-slate-900">₹100</span>
                                </div>
                                <div class="flex justify-between items-center text-sm">
                                    <span class="text-slate-600 font-medium">Pants (2)</span>
                                    <span class="font-bold text-slate-900">₹60</span>
                                </div>
                                <div class="border-t border-dashed border-slate-300 pt-4 flex justify-between items-center">
                                    <span class="text-base font-bold text-slate-900">Total Price</span>
                                    <span class="text-xl font-black text-primary">₹160</span>
                                </div>
                            </div>
                        </div>
                        <button class="w-full py-4 rounded-xl font-bold text-sm bg-slate-900 text-white hover:bg-slate-800 transition-all flex items-center justify-center gap-2 shadow-sm mt-4">
                            Pay via Razorpay
                        </button>
                    </div>

                    <!-- Screen 4: Receive Clothes -->
                    <div class="step-screen absolute inset-0 flex flex-col justify-between transition-all duration-500 ease-out opacity-0 scale-95 pointer-events-none" data-index="3">
                        <div class="flex-1 flex flex-col items-center justify-center text-center px-4">
                            <div class="w-20 h-20 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 mb-6 shadow-inner border border-emerald-200">
                                <Check class="w-10 h-10" />
                            </div>
                            <h3 class="font-display font-bold text-2xl text-slate-900 mb-2">Delivered!</h3>
                            <p class="text-sm text-slate-500 mb-8 leading-relaxed">Your clothes are returned perfectly pressed and ready to wear.</p>
                            
                            <div class="flex gap-1.5 mb-3">
                                <Star class="w-6 h-6 fill-amber-400 text-amber-400" />
                                <Star class="w-6 h-6 fill-amber-400 text-amber-400" />
                                <Star class="w-6 h-6 fill-amber-400 text-amber-400" />
                                <Star class="w-6 h-6 fill-amber-400 text-amber-400" />
                                <Star class="w-6 h-6 fill-amber-400 text-amber-400" />
                            </div>
                            <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Rated 5.0 for Classic Dhobi</span>
                        </div>
                        <div class="p-4 bg-emerald-50 rounded-xl border border-emerald-100 text-center text-sm font-semibold text-emerald-700 mt-4">
                            ✨ Wardrobe Hangers Returned
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Right: SaaS Stepper -->
        <div class="order-1 lg:order-2 lg:pl-12 flex flex-col justify-center">
            <div class="mb-14">
                <span class="inline-block px-4 py-1.5 rounded-full bg-primary/10 text-primary font-bold text-sm mb-4">How It Works</span>
                <h2 class="font-display text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight">The Pressly Process</h2>
            </div>

            <div class="space-y-0 relative">
                <!-- Step 1 -->
                <div class="step-indicator group cursor-pointer flex gap-6 pb-12 relative" data-index="0" data-state="active">
                    <!-- Line connector -->
                    <div class="absolute left-6 top-14 bottom-0 w-0.5 bg-slate-100 group-data-[state=active]:bg-primary/20 transition-colors duration-500"></div>
                    
                    <div class="w-12 h-12 rounded-full bg-white border-4 border-slate-100 text-slate-400 flex items-center justify-center group-data-[state=active]:border-primary group-data-[state=active]:bg-primary group-data-[state=active]:text-white z-10 shrink-0 transition-all duration-300 shadow-sm mt-1">
                        <Store class="w-5 h-5" />
                    </div>
                    <div class="pt-2">
                        <h3 class="text-xl font-bold text-slate-400 group-data-[state=active]:text-slate-900 mb-2 transition-colors">Choose Vendor</h3>
                        <p class="text-slate-500 max-h-0 opacity-0 group-data-[state=active]:max-h-24 group-data-[state=active]:opacity-100 transition-all duration-500 overflow-hidden leading-relaxed pr-8">Select your preferred local vendor based on upfront rates, ratings, and distance right from the app.</p>
                    </div>
                </div>
                <!-- Step 2 -->
                <div class="step-indicator group cursor-pointer flex gap-6 pb-12 relative" data-index="1" data-state="inactive">
                    <!-- Line connector -->
                    <div class="absolute left-6 top-14 bottom-0 w-0.5 bg-slate-100 group-data-[state=active]:bg-primary/20 transition-colors duration-500"></div>
                    
                    <div class="w-12 h-12 rounded-full bg-white border-4 border-slate-100 text-slate-400 flex items-center justify-center group-data-[state=active]:border-primary group-data-[state=active]:bg-primary group-data-[state=active]:text-white z-10 shrink-0 transition-all duration-300 shadow-sm mt-1">
                        <Calendar class="w-5 h-5" />
                    </div>
                    <div class="pt-2">
                        <h3 class="text-xl font-bold text-slate-400 group-data-[state=active]:text-slate-900 mb-2 transition-colors">Schedule Pickup</h3>
                        <p class="text-slate-500 max-h-0 opacity-0 group-data-[state=active]:max-h-24 group-data-[state=active]:opacity-100 transition-all duration-500 overflow-hidden leading-relaxed pr-8">Pick a date and convenient 1-hour time window that works best for your daily schedule.</p>
                    </div>
                </div>
                <!-- Step 3 -->
                <div class="step-indicator group cursor-pointer flex gap-6 pb-12 relative" data-index="2" data-state="inactive">
                    <!-- Line connector -->
                    <div class="absolute left-6 top-14 bottom-0 w-0.5 bg-slate-100 group-data-[state=active]:bg-primary/20 transition-colors duration-500"></div>
                    
                    <div class="w-12 h-12 rounded-full bg-white border-4 border-slate-100 text-slate-400 flex items-center justify-center group-data-[state=active]:border-primary group-data-[state=active]:bg-primary group-data-[state=active]:text-white z-10 shrink-0 transition-all duration-300 shadow-sm mt-1">
                        <UserCheck class="w-5 h-5" />
                    </div>
                    <div class="pt-2">
                        <h3 class="text-xl font-bold text-slate-400 group-data-[state=active]:text-slate-900 mb-2 transition-colors">Vendor Collects</h3>
                        <p class="text-slate-500 max-h-0 opacity-0 group-data-[state=active]:max-h-24 group-data-[state=active]:opacity-100 transition-all duration-500 overflow-hidden leading-relaxed pr-8">Vendor arrives, counts items at your doorstep, and locks the price in an instant digital receipt.</p>
                    </div>
                </div>
                <!-- Step 4 -->
                <div class="step-indicator group cursor-pointer flex gap-6 relative" data-index="3" data-state="inactive">
                    <div class="w-12 h-12 rounded-full bg-white border-4 border-slate-100 text-slate-400 flex items-center justify-center group-data-[state=active]:border-primary group-data-[state=active]:bg-primary group-data-[state=active]:text-white z-10 shrink-0 transition-all duration-300 shadow-sm mt-1">
                        <Check class="w-5 h-5" />
                    </div>
                    <div class="pt-2">
                        <h3 class="text-xl font-bold text-slate-400 group-data-[state=active]:text-slate-900 mb-2 transition-colors">Receive Clothes</h3>
                        <p class="text-slate-500 max-h-0 opacity-0 group-data-[state=active]:max-h-24 group-data-[state=active]:opacity-100 transition-all duration-500 overflow-hidden leading-relaxed pr-8">Your freshly pressed clothes are returned on hangers, crisp and ready to wear immediately.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Client Interaction Script -->
<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Find all interactive sections
        const sections = document.querySelectorAll('.how-it-works-section');
        
        sections.forEach(section => {
            const stepIndicators = section.querySelectorAll('.step-indicator');
            const stepScreens = section.querySelectorAll('.step-screen');

            function activateStep(index) {
                // Update Indicators states
                stepIndicators.forEach((indicator, i) => {
                    if (i === index) {
                        indicator.setAttribute('data-state', 'active');
                    } else {
                        indicator.setAttribute('data-state', 'inactive');
                    }
                });

                // Update Phone Screens
                stepScreens.forEach((screen, i) => {
                    if (i === index) {
                        screen.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
                        screen.classList.add('opacity-100', 'scale-100', 'pointer-events-auto');
                    } else {
                        screen.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto');
                        screen.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
                    }
                });
            }

            // Attach event listeners for each indicator in this section
            stepIndicators.forEach((btn, index) => {
                btn.addEventListener('click', () => activateStep(index));
                // Trigger on hover for ultra-smooth desktop experience
                btn.addEventListener('mouseenter', () => activateStep(index));
            });
        });
    });
</script>
