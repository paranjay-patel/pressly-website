									<div class="flex items-center gap-2.5">
										<div class="w-8 h-8 rounded-lg bg-slate-700 flex items-center justify-center text-white shrink-0"><Store class="w-4 h-4" /></div>
										<div class="text-left">
											<p class="text-xs font-bold">Classic Dhobi</p>
											<p class="text-[10px] text-slate-300">Fast delivery • 0.8 km</p>
										</div>
									</div>
									<div class="text-right">
										<div class="flex items-center gap-1 text-[11px] font-bold text-amber-400">
											<Star class="w-3 h-3 fill-amber-400 text-amber-400" /> 4.8
										</div>
										<p class="text-xs font-bold mt-0.5">₹12/item</p>
									</div>
								</div>

								<!-- Vendor 2 (Solid, no glassmorphism) -->
								<div class="p-3 bg-slate-50 rounded-xl border border-slate-200 flex justify-between items-center hover:bg-white transition-colors cursor-pointer">
									<div class="flex items-center gap-2.5">
										<div class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-primary shrink-0"><Store class="w-4 h-4" /></div>
										<div class="text-left">
											<p class="text-xs font-bold text-slate-900">Express Ironing</p>
											<p class="text-[10px] text-slate-500">Premium care • 1.2 km</p>
										</div>
									</div>
									<div class="text-right">
										<div class="flex items-center gap-1 text-[11px] font-bold text-amber-500">
											<Star class="w-3 h-3 fill-amber-500 text-amber-500" /> 4.9
										</div>
										<p class="text-xs font-bold text-slate-900 mt-0.5">₹15/item</p>
									</div>
								</div>
							</div>
						</div>

						<button class="w-full py-3.5 rounded-xl font-bold text-sm bg-slate-900 text-white hover:bg-slate-800 transition-all flex items-center justify-center gap-2 shadow-sm">
							Select Classic Dhobi <ArrowRight class="w-4 h-4" />
						</button>
					</div>

					<!-- Screen 2: Schedule Pickup -->
					<div id="step-screen-2" class="absolute inset-0 flex flex-col justify-between transition-all duration-500 ease-out opacity-0 scale-95 pointer-events-none">
						<div>
							<h3 class="font-display font-bold text-lg text-slate-900 mb-1">Select Pickup Slot</h3>
							<p class="text-xs text-slate-500 mb-4">Choose a convenient time for doorstep pickup</p>
							
							<!-- Time slots grid -->
							<div class="grid grid-cols-2 gap-3 mb-4">
								<div class="p-3 bg-slate-900 text-white rounded-xl border border-slate-900 text-center shadow-sm">
									<p class="text-xs font-semibold">Today</p>
									<p class="text-sm font-bold mt-1">4 PM - 5 PM</p>
								</div>
								<div class="p-3 bg-slate-50 rounded-xl border border-slate-200 text-center hover:bg-white transition-colors cursor-pointer">
									<p class="text-xs text-slate-500 font-semibold">Tomorrow</p>
									<p class="text-sm font-bold text-slate-900 mt-1">9 AM - 10 AM</p>
								</div>
							</div>

							<!-- Address Bar (Solid) -->
							<div class="p-3.5 bg-slate-50 rounded-xl border border-slate-200 flex items-center gap-3">
								<div class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-primary shrink-0"><MapPin class="w-4 h-4" /></div>
								<div class="text-left">
									<p class="text-xs font-bold text-slate-900">Pickup Location</p>
