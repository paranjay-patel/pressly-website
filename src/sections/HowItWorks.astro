---
import { Calendar, Check, Star, MapPin, Sparkles, Clock, ArrowRight, Store, UserCheck, Shield } from '@lucide/astro';
---

<!-- 2. How it works (Interactive timeline) -->
<section id="how-it-works" class="py-32 bg-white border-t border-slate-200 relative overflow-hidden">
	<div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-20 items-center">
		<!-- Left: Interactive Mobile Mockup -->
