---
import { Sparkles, MapPin, Star, IndianRupee, Zap, Search } from '@lucide/astro';
---

<!-- Marketplace Explanation Section -->
<section id="marketplace-explanation" class="py-20 bg-white relative overflow-hidden">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
		<div class="bg-white rounded-[2.5rem] border-2 border-slate-200 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] p-8 md:p-12 lg:p-16 overflow-hidden relative">
			<!-- Background subtle glow -->
			<div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 blur-[100px] rounded-full pointer-events-none"></div>

			<div class="flex flex-col lg:flex-row gap-12 lg:gap-20 relative z-10">
				<!-- Left Text & Context -->
				<div class="lg:w-5/12 flex flex-col justify-center">
					<span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-slate-100 border border-slate-200 text-slate-700 font-bold text-sm mb-6 w-max">
						<Sparkles class="w-4 h-4 text-primary" />
						Your Choice, Your Way
					</span>
					<h2 class="font-display text-3xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-6">
						Two Ways to Get It Done
					</h2>
					<p class="text-slate-600 text-base md:text-lg leading-relaxed mb-8">
						Whether you love to browse or prefer instant matching, our platform connects you with the perfect laundry partner using three transparent metrics.
					</p>

					<!-- Pillars -->
					<div class="flex flex-wrap gap-3">
						<div class="flex items-center gap-2 bg-slate-50 px-4 py-2.5 rounded-xl border border-slate-200">
							<MapPin class="w-4 h-4 text-sky-500" />
							<span class="text-sm font-bold text-slate-900">Distance</span>
						</div>
						<div class="flex items-center gap-2 bg-slate-50 px-4 py-2.5 rounded-xl border border-slate-200">
							<Star class="w-4 h-4 text-amber-500" />
							<span class="text-sm font-bold text-slate-900">Rating</span>
						</div>
						<div class="flex items-center gap-2 bg-slate-50 px-4 py-2.5 rounded-xl border border-slate-200">
							<IndianRupee class="w-4 h-4 text-emerald-500" />
							<span class="text-sm font-bold text-slate-900">Price</span>
						</div>
					</div>
				</div>

				<!-- Right Features (The Options) -->
				<div class="lg:w-7/12 grid grid-cols-1 sm:grid-cols-2 gap-6">
					<!-- Option 1: Choose Vendor -->
					<div class="bg-slate-50 border border-slate-200 rounded-3xl p-6 md:p-8 hover:bg-slate-100 transition-colors">
						<div class="w-12 h-12 rounded-2xl bg-white border border-slate-200 text-slate-900 flex items-center justify-center mb-6 shadow-sm">
							<Search class="w-6 h-6" />
						</div>
						<h3 class="text-xl font-bold text-slate-900 mb-3">Choose Vendor</h3>
						<p class="text-slate-600 text-sm leading-relaxed">
							Browse curated local professionals. Compare profiles, read reviews, and handpick your preferred partner manually.
						</p>
					</div>

					<!-- Option 2: Auto Match -->
					<div class="bg-primary/5 border border-primary/20 rounded-3xl p-6 md:p-8 relative overflow-hidden group hover:bg-primary/10 transition-colors">
						<div class="w-12 h-12 rounded-2xl bg-primary text-white flex items-center justify-center mb-6 relative z-10 shadow-sm">
							<Zap class="w-6 h-6" />
						</div>
						<h3 class="text-xl font-bold text-slate-900 mb-3 relative z-10">Find Best Vendor</h3>
						<p class="text-slate-600 text-sm leading-relaxed relative z-10">
							In a rush? Let us instantly assign the most optimal vendor for your location and schedule. No scrolling required.
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
