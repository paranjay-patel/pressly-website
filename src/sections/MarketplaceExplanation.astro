---
import { Sparkles, Search, Check, Zap } from '@lucide/astro';
---

<!-- Marketplace Explanation Section: Process Comparison -->
<section id="marketplace-explanation" class="py-24 bg-slate-50 relative overflow-hidden border-t border-slate-200">
    <!-- Subtle Background Element -->
    <div class="absolute top-0 right-0 w-32 h-32 bg-primary/20 rounded-full blur-2xl opacity-50 -translate-y-1/2 translate-x-1/4 pointer-events-none animate-blob"></div>

    <div class="max-w-5xl mx-auto px-6 text-center relative z-10">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-slate-200/70 border border-slate-200 text-slate-700 font-bold text-sm mb-6 shadow-sm">
            <Sparkles class="w-4 h-4 text-primary" /> Your Choice, Your Way
        </span>
        <h2 class="font-display text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-16">Compare the Experience</h2>

        <div class="grid md:grid-cols-2 gap-px bg-slate-200 rounded-[2rem] overflow-hidden border border-slate-200 shadow-2xl shadow-slate-200/50">
            <!-- Manual -->
            <div class="bg-white p-10 lg:p-14 text-left">
                <h3 class="text-2xl font-bold text-slate-900 mb-8 pb-4 border-b border-slate-100 flex justify-between items-center">
                    Choose Manually
                    <Search class="w-6 h-6 text-slate-400"/>
                </h3>
                <ul class="space-y-8 relative">
                    <!-- Connecting line -->
                    <div class="absolute left-6 top-6 bottom-6 w-px bg-slate-100"></div>
                    
                    <li class="flex gap-6 relative z-10">
                        <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-slate-200 flex items-center justify-center shrink-0 text-slate-600 font-bold">1</div>
                        <div>
                            <p class="font-bold text-slate-900">Scroll & Browse</p>
                            <p class="text-sm text-slate-500 mt-1">Look through all available vendors in your area.</p>
                        </div>
                    </li>
                    <li class="flex gap-6 relative z-10">
                        <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-slate-200 flex items-center justify-center shrink-0 text-slate-600 font-bold">2</div>
                        <div>
                            <p class="font-bold text-slate-900">Compare Metrics</p>
                            <p class="text-sm text-slate-500 mt-1">Check their distance, prices, and read reviews.</p>
                        </div>
                    </li>
                    <li class="flex gap-6 relative z-10">
                        <div class="w-12 h-12 rounded-full bg-slate-900 border-2 border-slate-900 flex items-center justify-center shrink-0 text-white font-bold"><Check class="w-5 h-5"/></div>
                        <div>
                            <p class="font-bold text-slate-900">Book Selected</p>
                            <p class="text-sm text-slate-500 mt-1">Confirm your booking with your chosen partner.</p>
                        </div>
                    </li>
                </ul>
            </div>

            <!-- Auto -->
            <div class="bg-white p-10 lg:p-14 text-left relative overflow-hidden group hover:bg-slate-50/50 transition-colors">
                <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-primary/5 rounded-full blur-[80px] pointer-events-none -translate-y-1/2 translate-x-1/4"></div>
                <h3 class="text-2xl font-bold text-slate-900 mb-8 pb-4 border-b border-slate-100 flex justify-between items-center text-primary">
                    Auto Match
                    <Zap class="w-6 h-6 text-primary"/>
                </h3>
                <ul class="space-y-8 relative">
                    <!-- Connecting line -->
                    <div class="absolute left-6 top-6 bottom-20 w-px bg-primary/20"></div>
                    
                    <li class="flex gap-6 relative z-10">
                        <div class="w-12 h-12 rounded-full bg-primary/10 border-2 border-primary/20 flex items-center justify-center shrink-0 text-primary font-bold shadow-inner">1</div>
                        <div>
                            <p class="font-bold text-slate-900">Tap Auto Match</p>
                            <p class="text-sm text-slate-500 mt-1">Just one click on the homepage.</p>
                        </div>
                    </li>
                    <li class="flex gap-6 relative z-10 opacity-40">
                        <div class="w-12 h-12 rounded-full bg-slate-50 border-2 border-slate-200 flex items-center justify-center shrink-0 text-slate-400 font-bold"><Zap class="w-4 h-4"/></div>
                        <div>
                            <p class="font-bold text-slate-400">Algorithm Calculates</p>
                            <p class="text-sm text-slate-400 mt-1">We balance distance, price & rating in ms.</p>
                        </div>
                    </li>
                    <li class="flex gap-6 relative z-10">
                        <div class="w-12 h-12 rounded-full bg-primary border-2 border-primary flex items-center justify-center shrink-0 text-white font-bold shadow-md shadow-primary/20"><Check class="w-5 h-5"/></div>
                        <div>
                            <p class="font-bold text-slate-900">Instantly Booked</p>
                            <p class="text-sm text-slate-500 mt-1">The absolute best vendor is assigned.</p>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>
