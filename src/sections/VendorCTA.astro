---
import { Store, TrendingUp, Users, ClipboardList, ArrowRight, Banknote, MapPin, CheckCircle2, BarChart3 } from '@lucide/astro';
---

<div class="bg-slate-100">
	<!-- Variant 1: Original Interactive Mockup -->
	<section class="py-20 bg-slate-50 relative overflow-hidden border-y border-slate-200 shadow-sm">
		<div class="max-w-7xl mx-auto px-6 relative z-10">
			<div class="bg-white rounded-[2.5rem] border border-slate-200 p-8 md:p-10 lg:p-12 shadow-sm flex flex-col-reverse lg:flex-row items-center justify-between gap-12 overflow-hidden relative group">
				<div class="relative w-full max-w-[320px] lg:w-[45%] perspective-1000 shrink-0">
					<div class="relative w-[280px] mx-auto transform-gpu transition-all duration-700 ease-out group-hover:-rotate-y-6 group-hover:rotate-x-2 group-hover:-translate-y-2">
						<div class="relative rounded-[2rem] bg-slate-900 p-1.5 shadow-2xl border-[3px] border-slate-800">
							<div class="bg-slate-50 rounded-[1.5rem] overflow-hidden relative h-[420px]">
								<div class="bg-primary p-5 pb-6 text-white relative">
									<h4 class="font-bold text-base mb-0.5 relative z-10">Pressly Partner</h4>
									<p class="text-white/80 text-xs relative z-10">Online & Accepting Orders</p>
									<div class="mt-4 bg-white/20 rounded-xl p-2.5 border border-white/20">
										<p class="text-white/60 text-[10px]">Today's Revenue</p>
										<p class="font-bold text-xl">₹3,450</p>
									</div>
								</div>
								<div class="p-3 -mt-3 relative z-10">
									<div class="bg-white rounded-xl p-3 shadow-sm border border-slate-100 cursor-pointer hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 relative overflow-hidden group/order">
										<p class="text-[10px] font-bold text-primary mb-0.5 tracking-wider uppercase">New Request</p>
										<h5 class="font-bold text-slate-900 text-base mb-1">12 Items • Ironing</h5>
										<div class="flex items-center gap-1.5 text-slate-500 text-xs mb-3"><MapPin class="w-3 h-3" /> 0.8 km away</div>
										<button class="w-full py-2 bg-slate-900 text-white rounded-lg font-bold text-xs group-hover/order:bg-primary transition-colors">Accept Order</button>
									</div>
									<div class="bg-white rounded-xl p-3 shadow-sm border border-slate-100 mt-3 opacity-70">
										<p class="text-[10px] font-bold text-slate-400 mb-0.5 tracking-wider uppercase">Completed</p>
										<h5 class="font-bold text-slate-900 text-sm">8 Items • Delivery</h5>
										<p class="text-emerald-500 font-bold text-xs mt-1">₹180 Earned</p>
									</div>
								</div>
							</div>
						</div>
						<div class="absolute top-10 -left-10 bg-white rounded-xl p-3 shadow-lg border border-slate-100 flex items-center gap-2 animate-[float_4s_ease-in-out_infinite] z-20">
							<div class="w-8 h-8 rounded-full bg-emerald-50 flex items-center justify-center shrink-0"><Banknote class="w-4 h-4 text-emerald-500" /></div>
							<div><p class="text-[9px] text-slate-500 font-bold uppercase tracking-wider">Weekly Payout</p><p class="text-sm font-black text-slate-900">₹12,450</p></div>
						</div>
						<div class="absolute bottom-10 -right-6 bg-white rounded-xl p-3 shadow-lg border border-slate-100 flex flex-col items-center gap-1 animate-[float_4s_ease-in-out_infinite_2s] z-20">
							<div class="flex text-amber-400 text-sm">★★★★★</div>
							<p class="text-[9px] font-bold text-slate-900 uppercase tracking-wider mt-0.5">Top Rated Vendor</p>
						</div>
					</div>
				</div>
				<div class="w-full lg:w-[55%] relative z-20 flex flex-col justify-center">
					<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-200 text-primary font-bold text-xs mb-5 self-start shadow-sm">
						<Store class="w-3.5 h-3.5" /> Partner with Pressly
					</div>
					<h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 mb-4 tracking-tight leading-tight">Own An <span class="text-primary">Ironing Shop?</span></h2>
					<p class="text-base md:text-lg text-slate-600 mb-8 leading-relaxed max-w-lg">Modernize your local business instantly. Reach hundreds of nearby households looking for premium ironing services.</p>
					<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
						<div class="flex flex-col items-start gap-2 p-4 rounded-2xl bg-slate-50 border border-slate-100 hover:border-slate-200 hover:shadow-sm transition-all duration-300">
							<div class="w-10 h-10 rounded-xl bg-sky-100 flex items-center justify-center"><TrendingUp class="w-5 h-5 text-primary" /></div>
							<h4 class="font-bold text-slate-900 text-sm">Grow Business</h4>
							<p class="text-xs text-slate-500">Increase daily orders</p>
						</div>
						<div class="flex flex-col items-start gap-2 p-4 rounded-2xl bg-slate-50 border border-slate-100 hover:border-slate-200 hover:shadow-sm transition-all duration-300">
							<div class="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center"><Users class="w-5 h-5 text-emerald-600" /></div>
							<h4 class="font-bold text-slate-900 text-sm">Get Customers</h4>
							<p class="text-xs text-slate-500">Target local households</p>
						</div>
						<div class="flex flex-col items-start gap-2 p-4 rounded-2xl bg-slate-50 border border-slate-100 hover:border-slate-200 hover:shadow-sm transition-all duration-300">
							<div class="w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center"><ClipboardList class="w-5 h-5 text-amber-600" /></div>
							<h4 class="font-bold text-slate-900 text-sm">Manage Orders</h4>
							<p class="text-xs text-slate-500">One digital dashboard</p>
						</div>
					</div>
					<div class="relative w-full sm:w-auto sm:self-start p-[3px] rounded-xl overflow-hidden group shadow-lg hover:-translate-y-0.5 transition-transform duration-300">
						<!-- Spinning border line -->
						<div class="absolute inset-[-1000%] animate-[spin_3s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,#0f172a_0%,#0ea5e9_30%,#a855f7_40%,#ec4899_50%,#0f172a_60%,#0f172a_100%)]"></div>
						
						<!-- Actual button -->
						<a href="/vendor" class="relative w-full h-full inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-[9px] font-bold text-sm bg-slate-900 text-white hover:bg-slate-800 transition-colors duration-300">
							Become Vendor <ArrowRight class="w-4 h-4" />
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

    <!-- Variant 2: Split Screen Modern -->
    <section class="hidden py-24 bg-slate-50 relative border-y border-slate-200 shadow-sm">
        <div class="absolute top-4 left-4 z-50 bg-slate-800 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">Variant 2: Split Screen Solid Block</div>
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col lg:flex-row bg-slate-900 rounded-[3rem] overflow-hidden shadow-2xl">
                <!-- Left: Content -->
                <div class="lg:w-1/2 p-12 lg:p-20 flex flex-col justify-center text-white relative">
                    <div class="absolute top-0 right-0 w-64 h-64 bg-primary/20 blur-[80px] rounded-full pointer-events-none"></div>
                    <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 border border-white/10 font-bold text-sm mb-8 w-max">
                        <Store class="w-4 h-4" /> Partner with Pressly
                    </span>
                    <h2 class="font-display text-4xl md:text-5xl font-extrabold mb-6 tracking-tight">Turn your local shop into a digital business.</h2>
                    <p class="text-slate-400 text-lg mb-10 leading-relaxed max-w-md">Get a dedicated vendor app to receive orders, track revenue, and connect with hundreds of new customers in your neighborhood.</p>
                    
                    <ul class="space-y-4 mb-12">
                        <li class="flex items-center gap-3"><CheckCircle2 class="w-5 h-5 text-emerald-400"/> Zero setup fees to join</li>
                        <li class="flex items-center gap-3"><CheckCircle2 class="w-5 h-5 text-emerald-400"/> Weekly automatic payouts</li>
                        <li class="flex items-center gap-3"><CheckCircle2 class="w-5 h-5 text-emerald-400"/> Full control over pricing & capacity</li>
                    </ul>

                    <a href="/vendor" class="inline-flex items-center justify-center gap-2 w-max px-8 py-4 rounded-xl font-bold text-slate-900 bg-white hover:bg-slate-100 hover:-translate-y-0.5 transition-all duration-300">
                        Join as a Vendor <ArrowRight class="w-4 h-4" />
                    </a>
                </div>
                <!-- Right: Graphic -->
                <div class="lg:w-1/2 bg-primary relative overflow-hidden flex flex-col items-center justify-end pt-12 px-12">
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.2)_0%,transparent_70%)]"></div>
                    <!-- Minimal Mockup peeking from bottom -->
                    <div class="relative w-full max-w-sm rounded-t-[2rem] bg-white p-2 pb-0 shadow-2xl translate-y-4 hover:translate-y-0 transition-transform duration-500 cursor-pointer">
                        <div class="bg-slate-50 rounded-t-[1.5rem] border border-slate-200 h-[400px] w-full p-6">
                            <div class="flex justify-between items-center mb-8">
                                <div>
                                    <p class="text-slate-500 text-xs font-bold uppercase mb-1">Dashboard</p>
                                    <h3 class="font-bold text-xl text-slate-900">₹12,450</h3>
                                </div>
                                <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center"><BarChart3 class="w-6 h-6 text-primary"/></div>
                            </div>
                            <div class="space-y-3">
                                <div class="p-4 bg-white rounded-xl shadow-sm border border-slate-100 flex justify-between items-center">
                                    <div><p class="font-bold text-slate-900 text-sm">New Request</p><p class="text-xs text-slate-500">12 items • Ironing</p></div>
                                    <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600"><CheckCircle2 class="w-4 h-4"/></div>
                                </div>
                                <div class="p-4 bg-white rounded-xl shadow-sm border border-slate-100 flex justify-between items-center opacity-50">
                                    <div><p class="font-bold text-slate-900 text-sm">Completed</p><p class="text-xs text-slate-500">8 items • Delivery</p></div>
                                    <span class="text-xs font-bold text-slate-400">₹180</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
