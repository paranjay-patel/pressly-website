---
import { Store, TrendingUp, Users, ClipboardList, ArrowRight, Banknote, MapPin } from '@lucide/astro';
---

<!-- Vendor Acquisition Section -->
<section id="vendor-cta" class="py-16 md:py-20 bg-slate-50 relative overflow-hidden border-t border-slate-200">
	<div class="max-w-7xl mx-auto px-6 relative z-10">
		<div class="bg-white rounded-[2.5rem] border border-slate-200 p-8 md:p-10 lg:p-12 shadow-sm flex flex-col-reverse lg:flex-row items-center justify-between gap-12 overflow-hidden relative group">
			
			<!-- Left Side: Interactive Mockup (Scaled down slightly) -->
			<div class="relative w-full max-w-[320px] lg:w-[45%] perspective-1000 shrink-0">
				<div class="relative w-[280px] mx-auto transform-gpu transition-all duration-700 ease-out group-hover:-rotate-y-6 group-hover:rotate-x-2 group-hover:-translate-y-2">
					
					<!-- Phone Frame -->
					<div class="relative rounded-[2rem] bg-slate-900 p-1.5 shadow-2xl border-[3px] border-slate-800">
						<!-- Screen -->
						<div class="bg-slate-50 rounded-[1.5rem] overflow-hidden relative h-[420px]">
							<!-- Header -->
							<div class="bg-primary p-5 pb-6 text-white relative">
								<h4 class="font-bold text-base mb-0.5 relative z-10">Pressly Partner</h4>
								<p class="text-white/80 text-xs relative z-10">Online & Accepting Orders</p>
								
								<!-- Stat -->
								<div class="mt-4 bg-white/20 rounded-xl p-2.5 border border-white/20">
									<p class="text-white/60 text-[10px]">Today's Revenue</p>
									<p class="font-bold text-xl">₹3,450</p>
								</div>
							</div>
							
							<!-- Body -->
							<div class="p-3 -mt-3 relative z-10">
								<!-- Order Request -->
								<div class="bg-white rounded-xl p-3 shadow-sm border border-slate-100 cursor-pointer hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 relative overflow-hidden group/order">
									<p class="text-[10px] font-bold text-primary mb-0.5 tracking-wider uppercase">New Request</p>
									<h5 class="font-bold text-slate-900 text-base mb-1">12 Items • Ironing</h5>
									
									<div class="flex items-center gap-1.5 text-slate-500 text-xs mb-3">
										<MapPin class="w-3 h-3" /> 0.8 km away
									</div>
									
									<button class="w-full py-2 bg-slate-900 text-white rounded-lg font-bold text-xs group-hover/order:bg-primary transition-colors">
										Accept Order
									</button>
								</div>

								<!-- Past Order -->
								<div class="bg-white rounded-xl p-3 shadow-sm border border-slate-100 mt-3 opacity-70">
									<p class="text-[10px] font-bold text-slate-400 mb-0.5 tracking-wider uppercase">Completed</p>
									<h5 class="font-bold text-slate-900 text-sm">8 Items • Delivery</h5>
									<p class="text-emerald-500 font-bold text-xs mt-1">₹180 Earned</p>
								</div>
							</div>
						</div>
					</div>

					<!-- Floating badges -->
					<div class="absolute top-10 -left-10 bg-white rounded-xl p-3 shadow-lg border border-slate-100 flex items-center gap-2 animate-[float_4s_ease-in-out_infinite] z-20">
						<div class="w-8 h-8 rounded-full bg-emerald-50 flex items-center justify-center shrink-0">
							<Banknote class="w-4 h-4 text-emerald-500" />
						</div>
						<div>
							<p class="text-[9px] text-slate-500 font-bold uppercase tracking-wider">Weekly Payout</p>
							<p class="text-sm font-black text-slate-900">₹12,450</p>
						</div>
					</div>

					<div class="absolute bottom-10 -right-6 bg-white rounded-xl p-3 shadow-lg border border-slate-100 flex flex-col items-center gap-1 animate-[float_4s_ease-in-out_infinite_2s] z-20">
						<div class="flex text-amber-400 text-sm">
							★★★★★
						</div>
						<p class="text-[9px] font-bold text-slate-900 uppercase tracking-wider mt-0.5">Top Rated Vendor</p>
					</div>

				</div>
			</div>

			<!-- Right Side: Content -->
			<div class="w-full lg:w-[55%] relative z-20 flex flex-col justify-center">
				<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-slate-50 border border-slate-200 text-primary font-bold text-xs mb-5 self-start">
					<Store class="w-3.5 h-3.5" />
					Partner with Pressly
				</div>
				
				<h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-extrabold text-slate-900 mb-4 tracking-tight leading-tight">
					Own An <span class="text-primary">Ironing Shop?</span>
				</h2>
				
				<p class="text-base md:text-lg text-slate-600 mb-8 leading-relaxed max-w-lg">
					Modernize your local business instantly. Reach hundreds of nearby households looking for premium ironing services.
				</p>
				
				<!-- Compact Grid for Features -->
				<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
					<div class="flex flex-col items-start gap-2 p-4 rounded-2xl bg-slate-50 border border-slate-100 hover:border-slate-200 hover:shadow-sm transition-all duration-300">
						<div class="w-10 h-10 rounded-xl bg-sky-100 flex items-center justify-center">
							<TrendingUp class="w-5 h-5 text-primary" />
						</div>
						<h4 class="font-bold text-slate-900 text-sm">Grow Business</h4>
						<p class="text-xs text-slate-500">Increase daily orders</p>
					</div>
					
					<div class="flex flex-col items-start gap-2 p-4 rounded-2xl bg-slate-50 border border-slate-100 hover:border-slate-200 hover:shadow-sm transition-all duration-300">
						<div class="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center">
							<Users class="w-5 h-5 text-emerald-600" />
						</div>
						<h4 class="font-bold text-slate-900 text-sm">Get Customers</h4>
						<p class="text-xs text-slate-500">Target local households</p>
					</div>
					
					<div class="flex flex-col items-start gap-2 p-4 rounded-2xl bg-slate-50 border border-slate-100 hover:border-slate-200 hover:shadow-sm transition-all duration-300">
						<div class="w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center">
							<ClipboardList class="w-5 h-5 text-amber-600" />
						</div>
						<h4 class="font-bold text-slate-900 text-sm">Manage Orders</h4>
						<p class="text-xs text-slate-500">One digital dashboard</p>
					</div>
				</div>

				<a href="/vendor" onclick="if(typeof window.trackEvent === 'function') window.trackEvent('cta_click', { location: 'vendor_section', type: 'partner' })" class="inline-flex items-center justify-center gap-2 self-start px-6 py-3.5 rounded-xl font-bold text-sm bg-slate-900 text-white hover:bg-primary hover:-translate-y-0.5 transition-all duration-300">
					Become Vendor
					<ArrowRight class="w-4 h-4" />
				</a>
			</div>
			
		</div>
	</div>
</section>
