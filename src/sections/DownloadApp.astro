---
import AppleIcon from '../components/icons/AppleIcon.astro';
import GooglePlayIcon from '../components/icons/GooglePlayIcon.astro';
---

<!-- 6. Customer CTA -->
	<section id="download" class="py-32 bg-primary relative overflow-hidden">
		<!-- Glowing Orbs -->
		<div class="absolute top-0 right-0 w-[600px] h-[600px] bg-sky-400/30 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 pointer-events-none z-0"></div>
		<div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-sky-300/40 rounded-full blur-[120px] translate-y-1/3 -translate-x-1/4 pointer-events-none z-0"></div>
		<div class="absolute top-1/2 right-0 w-[300px] h-[300px] bg-sky-200/40 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/3 pointer-events-none z-0"></div>

		<!-- Subtle Grid Texture with Gradient Opacity -->
		<div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff15_1px,transparent_1px),linear-gradient(to_bottom,#ffffff15_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:linear-gradient(to_bottom,white_0%,white_20%,transparent_100%)] z-10 pointer-events-none"></div>
		
		<div class="max-w-7xl mx-auto px-6 w-full relative z-20">
			<div class="relative group cursor-default">
				<!-- The Ticket -->
				<div class="relative flex flex-col md:flex-row bg-white rounded-3xl border border-slate-200 overflow-hidden">
					
					<!-- Left Side: Ticket Details (Receipt style) -->
					<div class="w-full md:w-4/12 bg-slate-50 p-10 md:p-14 flex flex-col justify-between border-b md:border-b-0 md:border-r-2 border-dashed border-slate-300 relative">
						<!-- Cutout semi-circles for the ticket effect -->
						<div class="hidden md:block absolute -right-4 top-0 w-8 h-8 bg-white rounded-full translate-y-[-50%] shadow-[inset_0_-2px_4px_rgba(0,0,0,0.05)] border-b border-slate-200"></div>
						<div class="hidden md:block absolute -right-4 bottom-0 w-8 h-8 bg-white rounded-full translate-y-[50%] shadow-[inset_0_2px_4px_rgba(0,0,0,0.05)] border-t border-slate-200"></div>
						
						<div>
							<div class="flex items-center justify-between mb-8">
								<span class="font-mono text-xs font-bold text-slate-500 uppercase tracking-widest">TICKET #8492</span>
								<span class="font-mono text-xs font-bold text-emerald-500 bg-emerald-100 px-2 py-1 rounded">PAID</span>
							</div>
							
							<div class="space-y-4 mb-8">
								<div class="flex justify-between items-end border-b border-slate-200 pb-2">
									<span class="font-medium text-slate-600">Laundry Stress</span>
									<span class="font-mono font-bold text-slate-900 line-through decoration-rose-500 decoration-2">100%</span>
								</div>
								<div class="flex justify-between items-end border-b border-slate-200 pb-2">
									<span class="font-medium text-slate-600">Wasted Weekends</span>
									<span class="font-mono font-bold text-slate-900 line-through decoration-rose-500 decoration-2">5 hrs</span>
								</div>
								<div class="flex justify-between items-end border-b border-slate-200 pb-2">
									<span class="font-bold text-primary">Pressly Magic</span>
									<span class="font-mono font-bold text-primary">PRICELESS</span>
								</div>
							</div>
						</div>
						
						<!-- Fake Barcode -->
						<div class="w-full h-12 flex justify-between items-end opacity-40">
							<div class="w-1 h-full bg-slate-800"></div><div class="w-2 h-full bg-slate-800"></div><div class="w-1 h-full bg-slate-800"></div><div class="w-3 h-full bg-slate-800"></div><div class="w-1 h-3/4 bg-slate-800"></div><div class="w-2 h-full bg-slate-800"></div><div class="w-1 h-full bg-slate-800"></div><div class="w-4 h-full bg-slate-800"></div><div class="w-1 h-3/4 bg-slate-800"></div><div class="w-2 h-full bg-slate-800"></div><div class="w-1 h-full bg-slate-800"></div><div class="w-2 h-full bg-slate-800"></div><div class="w-3 h-full bg-slate-800"></div><div class="w-1 h-full bg-slate-800"></div>
						</div>
					</div>

					<!-- Right Side: The Main Pitch & CTA -->
					<div class="w-full md:w-8/12 p-10 md:p-16 flex flex-col justify-center relative overflow-hidden bg-white">
						<!-- Subtle background icon -->
						<svg class="absolute -right-10 -bottom-10 w-64 h-64 text-slate-50 -rotate-12 pointer-events-none" fill="none" stroke="currentColor" stroke-width="0.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M4.5 10.5V18a2.25 2.25 0 002.25 2.25h10.5A2.25 2.25 0 0019.5 18v-7.5m-15 0v-7.5a2.25 2.25 0 012.25-2.25h10.5a2.25 2.25 0 012.25 2.25v7.5m-15 0h15M9 12.75h.008v.008H9v-.008zm0 3.75h.008v.008H9v-.008zm3-3.75h.008v.008H12v-.008zm0 3.75h.008v.008H12v-.008zm3-3.75h.008v.008H15v-.008zm0 3.75h.008v.008H15v-.008z"></path></svg>
						
						<div class="relative z-10">
							<h2 class="font-display text-4xl md:text-5xl font-extrabold text-slate-900 mb-6 tracking-tight leading-tight">
								Ready to clear your <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-sky-500">basket?</span>
							</h2>
							<p class="text-lg text-slate-600 mb-10 leading-relaxed max-w-md">
								Claim your ticket to a laundry-free weekend. Download Pressly now and let us handle the wrinkles.
							</p>
							
							<div class="flex flex-col sm:flex-row gap-4">
								<button onclick="if(typeof window.trackEvent === 'function') window.trackEvent('cta_click', { location: 'footer_cta', type: 'app_store' })" class="inline-flex items-center justify-center gap-3 px-6 py-4 rounded-xl font-bold text-white bg-slate-900 hover:bg-slate-800 transition-all duration-300 w-full sm:w-auto">
									<AppleIcon class="w-6 h-6" /> App Store
								</button>
								<button onclick="if(typeof window.trackEvent === 'function') window.trackEvent('cta_click', { location: 'footer_cta', type: 'google_play' })" class="inline-flex items-center justify-center gap-3 px-6 py-4 rounded-xl font-bold text-slate-700 bg-white border border-slate-300 hover:bg-slate-50 transition-all duration-300 w-full sm:w-auto">
									<GooglePlayIcon class="w-6 h-6" /> Google Play
								</button>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
