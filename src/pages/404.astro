---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found - Pressly">
	<div class="relative w-full py-32 lg:py-48 flex items-center justify-center selection:bg-primary/20 selection:text-primary overflow-hidden">
		

		<!-- Subtle premium grid background -->
		<div class="absolute inset-0 bg-[linear-gradient(to_right,#f1f5f9_1px,transparent_1px),linear-gradient(to_bottom,#f1f5f9_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-60 pointer-events-none z-0"></div>

		<!-- Floating Decorative Orbs -->
		<div class="absolute top-1/4 -left-10 w-64 h-64 bg-sky-200/60 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-[float_6s_ease-in-out_infinite] pointer-events-none -z-10"></div>
		<div class="absolute top-1/3 right-0 w-72 h-72 bg-primary/20 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-[float_6s_ease-in-out_infinite_2s] pointer-events-none -z-10"></div>

		<!-- 404 Content -->
		<div class="relative z-10 max-w-2xl mx-auto px-6 text-center">
			<!-- Massive 404 Text -->
			<h1 class="text-[8rem] md:text-[12rem] font-display font-extrabold text-transparent bg-clip-text bg-gradient-to-br from-slate-200 to-slate-300 mb-2 animate-fade-in-up drop-shadow-sm select-none" style="line-height: 1;">
				404
			</h1>
			
			<div class="animate-fade-in-up" style="animation-delay: 0.1s;">
				<h2 class="text-3xl md:text-5xl font-display font-bold text-slate-900 tracking-tight mb-4">
					Looks like this page <br class="hidden sm:block"/> <span class="text-primary">shrunk in the wash.</span>
				</h2>
				<p class="text-lg text-slate-500 font-medium mb-10 max-w-lg mx-auto">
					The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
				</p>
			</div>

			<div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up" style="animation-delay: 0.2s;">
				<a href="/" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-bold text-white bg-slate-900 hover:bg-slate-800 hover:-translate-y-1 transition-all shadow-[0_10px_20px_-10px_rgba(0,0,0,0.2)]">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
					Back to Homepage
				</a>
				<a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-bold text-slate-700 bg-white border border-slate-200 hover:bg-slate-50 hover:-translate-y-1 transition-all shadow-sm">
					Contact Support
				</a>
			</div>
		</div>


	</div>
</Layout>
