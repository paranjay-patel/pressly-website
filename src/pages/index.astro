---
import Layout from '../layouts/Layout.astro';
import Hero from '../sections/Hero.astro';
import Problem from '../sections/Problem.astro';
import HowItWorks from '../sections/HowItWorks.astro';
import MarketplaceExplanation from '../sections/MarketplaceExplanation.astro';
import Benefits from '../sections/Benefits.astro';
import VendorCTA from '../sections/VendorCTA.astro';
import DownloadApp from '../sections/DownloadApp.astro';
import FAQ from '../sections/FAQ.astro';
---

<Layout title="Pressly - Premium On-Demand Doorstep Ironing">
	<Hero />
	<Problem />
	<HowItWorks />
	<MarketplaceExplanation />
	<Benefits />
	<VendorCTA />
	<DownloadApp />
	<FAQ />
</Layout>

<style is:global>
	.perspective-1000 {
		perspective: 1000px;
	}

	details > summary {
		list-style: none;
	}
	details > summary::-webkit-details-marker {
		display: none;
	}
</style>
