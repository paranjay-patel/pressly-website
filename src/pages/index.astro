---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pressly - Premium On-Demand Doorstep Ironing">
	<!-- 1. Hero Section -->
	<section class="relative pt-12 pb-16 lg:pt-16 lg:pb-24 overflow-hidden">
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-sky-100/40 via-white to-white -z-10"></div>
		
		<div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
			<div class="flex flex-col items-center lg:items-start text-center lg:text-left z-10">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-100 border border-slate-200 text-primary font-semibold text-sm mb-6 animate-fade-in-up">
					<span class="relative flex h-2 w-2">
					  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
					  <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
					</span>
					Now serving Surat
				</div>
				<h1 class="font-display text-5xl lg:text-7xl font-black text-slate-900 tracking-tight leading-[1.1] mb-6">
					Flawless Ironing.<br />
					<span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">Zero Hassle.</span>
				</h1>
				<p class="text-lg lg:text-xl text-slate-600 mb-8 max-w-lg leading-relaxed">
					Reclaim your time. We connect you with local, top-rated ironing professionals. They pick up, count at your door, and deliver crisp clothes back to you.
				</p>
				<div class="flex flex-col sm:flex-row items-center gap-6 w-full lg:w-auto">
					<a href="#download" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 rounded-2xl font-bold text-lg bg-gradient-to-br from-primary to-accent text-white shadow-float hover:-translate-y-1 hover:shadow-[0_20px_40px_-10px_rgba(2,132,199,0.4)] transition-all duration-300">
						Download App
					</a>
					<div class="flex items-center gap-4">
						<div class="flex -space-x-3">
							<img class="w-10 h-10 rounded-full border-2 border-white" src="https://i.pravatar.cc/100?img=1" alt="User 1" />
							<img class="w-10 h-10 rounded-full border-2 border-white" src="https://i.pravatar.cc/100?img=2" alt="User 2" />
							<img class="w-10 h-10 rounded-full border-2 border-white" src="https://i.pravatar.cc/100?img=3" alt="User 3" />
						</div>
						<div class="text-sm text-left">
							<p class="text-slate-600">Join <span class="font-bold text-slate-900">10,000+</span></p>
							<p class="text-slate-600">happy customers</p>
						</div>
					</div>
				</div>
			</div>
			
			<div class="relative h-[500px] lg:h-[550px] flex justify-center items-center perspective-1000">
				<!-- Floating App Mockup -->
				<div class="relative w-[260px] h-[520px] bg-white rounded-[36px] border-[10px] border-slate-900 shadow-float transform rotate-y-[-15deg] rotate-x-[10deg] hover:rotate-y-0 hover:rotate-x-0 transition-transform duration-700 ease-out overflow-hidden flex flex-col z-20">
					<!-- App Header -->
					<div class="px-5 py-3 border-b border-slate-100 flex items-center gap-3 bg-white">
						<div class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.5)]"></div>
						<span class="font-bold text-slate-900 text-sm">Active Order</span>
					</div>
					<!-- App Body -->
					<div class="p-4 flex-1 flex flex-col gap-4 bg-slate-50">
						<div class="h-28 bg-slate-200 rounded-2xl relative overflow-hidden flex items-center justify-center">
							<div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 2px 2px, slate-400 1px, transparent 0); background-size: 16px 16px;"></div>
							<div class="bg-white px-3 py-1.5 rounded-full font-bold text-xs text-primary shadow-lg z-10 flex items-center gap-2">
								<span>📍</span> Sai Ironing
							</div>
						</div>
						<div class="relative flex flex-col gap-4 pl-8 mt-1">
							<div class="absolute left-2 top-2 bottom-6 w-0.5 bg-slate-200"></div>
							
							<div class="relative z-10">
								<div class="absolute -left-7 top-1 w-3.5 h-3.5 rounded-full border-4 border-primary bg-primary"></div>
								<h4 class="font-bold text-slate-900 text-xs">Clothes Counted</h4>
								<p class="text-[10px] text-slate-500 mt-0.5">5 Shirts, 2 Jeans</p>
							</div>
							
							<div class="relative z-10">
								<div class="absolute -left-7 top-1 w-3.5 h-3.5 rounded-full border-4 border-primary bg-primary"></div>
								<h4 class="font-bold text-slate-900 text-xs">Ironing in Progress</h4>
								<p class="text-[10px] text-slate-500 mt-0.5">Almost done</p>
							</div>
							
							<div class="relative z-10">
								<div class="absolute -left-7 top-1 w-3.5 h-3.5 rounded-full border-4 border-accent bg-white shadow-[0_0_0_4px_rgba(99,102,241,0.2)] animate-pulse"></div>
								<h4 class="font-bold text-slate-900 text-xs">Out for Delivery</h4>
								<p class="text-[10px] text-slate-500 mt-0.5">Arriving in 5 mins</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Floating Badges -->
				<div class="absolute top-16 -left-8 bg-white px-4 py-2.5 rounded-2xl shadow-xl font-bold text-xs border border-slate-100 flex items-center gap-2 animate-[float_4s_ease-in-out_infinite] z-30">
					👕 7 Items • ₹140
				</div>
				<div class="absolute bottom-28 -right-4 bg-white px-4 py-2.5 rounded-2xl shadow-xl font-bold text-xs border border-slate-100 text-emerald-600 flex items-center gap-2 animate-[float_4s_ease-in-out_infinite_2s] z-30">
					✨ Delivered Fresh
				</div>
			</div>
		</div>
	</section>

	<!-- 2. How it works (Interactive timeline) -->
	<section id="how-it-works" class="py-32 bg-slate-50 border-t border-slate-200">
		<div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-20 items-center">
			<div class="order-2 lg:order-1 perspective-1000">
				<!-- 3D Receipt Mockup -->
				<div class="bg-white p-10 rounded-[2rem] shadow-xl border border-slate-100 transform lg:rotate-y-[10deg] lg:rotate-x-[5deg] hover:rotate-0 transition-transform duration-500 max-w-md mx-auto lg:mx-0">
					<h3 class="text-center mb-8 font-display font-bold text-xl text-primary">Digital Receipt</h3>
					<div class="flex justify-between mb-4 text-slate-600 font-medium"><span>Shirts (5)</span> <span>₹100</span></div>
					<div class="flex justify-between mb-4 text-slate-600 font-medium"><span>Pants (2)</span> <span>₹60</span></div>
					<div class="h-px bg-[repeating-linear-gradient(90deg,var(--tw-colors-slate-300)_0,var(--tw-colors-slate-300)_8px,transparent_8px,transparent_16px)] my-6"></div>
					<div class="flex justify-between font-black text-xl text-slate-900 mb-8"><span>Total</span> <span>₹160</span></div>
					<button class="w-full py-4 rounded-xl font-bold bg-slate-900 text-white hover:bg-slate-800 transition-colors">Pay via Razorpay</button>
				</div>
			</div>
			
			<div class="order-1 lg:order-2">
				<span class="inline-block px-4 py-1.5 rounded-full bg-white text-primary font-semibold text-sm mb-4 border border-slate-200 shadow-sm">How It Works</span>
				<h2 class="font-display text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-12">Three Steps to Perfection</h2>
				
				<div class="flex flex-col gap-10">
					<div class="flex gap-6 group">
						<div class="w-14 h-14 rounded-full bg-white shadow-md border border-slate-100 flex items-center justify-center font-display font-black text-xl text-primary shrink-0 group-hover:scale-110 transition-transform">1</div>
						<div>
							<h4 class="text-xl font-bold text-slate-900 mb-2">Request Pickup</h4>
							<p class="text-slate-600 leading-relaxed">Choose a time slot that works for you. Our partner will arrive exactly on time at your doorstep.</p>
						</div>
					</div>
					<div class="flex gap-6 group">
						<div class="w-14 h-14 rounded-full bg-white shadow-md border border-slate-100 flex items-center justify-center font-display font-black text-xl text-primary shrink-0 group-hover:scale-110 transition-transform">2</div>
						<div>
							<h4 class="text-xl font-bold text-slate-900 mb-2">Verify & Handover</h4>
							<p class="text-slate-600 leading-relaxed">Items are counted together. You receive an instant digital receipt on your app locking in the exact price.</p>
						</div>
					</div>
					<div class="flex gap-6 group">
						<div class="w-14 h-14 rounded-full bg-white shadow-md border border-slate-100 flex items-center justify-center font-display font-black text-xl text-primary shrink-0 group-hover:scale-110 transition-transform">3</div>
						<div>
							<h4 class="text-xl font-bold text-slate-900 mb-2">Receive & Wear</h4>
							<p class="text-slate-600 leading-relaxed">Clothes are returned perfectly pressed on hangers or folded, ready to go straight into your wardrobe.</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- 3. Why Choose Us (Bento Grid) -->
	<section id="why-choose-us" class="py-32 bg-white">
		<div class="max-w-7xl mx-auto px-6">
			<div class="text-center max-w-2xl mx-auto mb-20">
				<span class="inline-block px-4 py-1.5 rounded-full bg-slate-100 text-primary font-semibold text-sm mb-4 border border-slate-200">Why Choose Us</span>
				<h2 class="font-display text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-6">The End of Laundry Disputes</h2>
				<p class="text-lg text-slate-600">We solved the biggest pain points of local ironing services by introducing technology where it matters most.</p>
			</div>
			
			<div class="grid md:grid-cols-3 gap-6 auto-rows-[300px]">
				<!-- Feature 1: Geo Discovery (Spans 2 columns on tablet+) -->
				<div class="md:col-span-2 group relative overflow-hidden rounded-[2rem] bg-slate-50 border border-slate-200 p-10 hover:border-primary/50 transition-colors duration-300">
					<div class="absolute top-0 right-0 w-64 h-64 bg-sky-100 rounded-full blur-3xl -mr-20 -mt-20 opacity-50 group-hover:opacity-100 transition-opacity"></div>
					<div class="relative z-10 flex flex-col h-full">
						<div class="w-14 h-14 rounded-2xl bg-white shadow-sm border border-slate-100 flex items-center justify-center text-2xl mb-6">📍</div>
						<h3 class="font-display text-2xl font-bold text-slate-900 mb-3">Geo-Discovery</h3>
						<p class="text-slate-600 leading-relaxed max-w-md">Find the best local vendors near your house. Compare prices, check their ratings, and book instantly without making a single phone call.</p>
					</div>
				</div>

				<!-- Feature 2: Doorstep Counting -->
				<div class="group relative overflow-hidden rounded-[2rem] bg-slate-50 border border-slate-200 p-10 hover:border-accent/50 transition-colors duration-300">
					<div class="absolute bottom-0 right-0 w-48 h-48 bg-indigo-100 rounded-full blur-3xl -mr-10 -mb-10 opacity-50 group-hover:opacity-100 transition-opacity"></div>
					<div class="relative z-10 flex flex-col h-full">
						<div class="w-14 h-14 rounded-2xl bg-white shadow-sm border border-slate-100 flex items-center justify-center text-2xl mb-6">🔢</div>
						<h3 class="font-display text-2xl font-bold text-slate-900 mb-3">Doorstep Counting</h3>
						<p class="text-slate-600 leading-relaxed">Stop worrying about missing clothes. The vendor physically counts items at your door.</p>
					</div>
				</div>

				<!-- Feature 3: Live Order Tracking (Spans full width) -->
				<div class="md:col-span-3 group relative overflow-hidden rounded-[2rem] bg-slate-900 border border-slate-800 p-10 flex flex-col md:flex-row items-center gap-10">
					<div class="absolute inset-0 bg-gradient-to-r from-primary/20 to-accent/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
					<div class="relative z-10 flex-1">
						<div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center text-2xl mb-6 backdrop-blur-md">🚚</div>
						<h3 class="font-display text-3xl font-bold text-white mb-4">Live Order Tracking</h3>
						<p class="text-slate-300 text-lg leading-relaxed max-w-2xl">From the moment clothes leave your hands to the moment they return crisp and fresh, track every step in real-time on your phone. No more guessing when your clothes will arrive.</p>
					</div>
					<div class="hidden md:flex relative z-10 w-full max-w-sm bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
						<!-- Mini timeline UI -->
						<div class="flex flex-col gap-6 w-full">
							<div class="flex items-center gap-4"><div class="w-4 h-4 rounded-full bg-emerald-400"></div><div class="h-2 bg-white/20 rounded-full flex-1"></div></div>
							<div class="flex items-center gap-4"><div class="w-4 h-4 rounded-full bg-emerald-400"></div><div class="h-2 bg-white/20 rounded-full flex-1"></div></div>
							<div class="flex items-center gap-4"><div class="w-4 h-4 rounded-full bg-primary shadow-[0_0_15px_rgba(2,132,199,0.5)]"></div><div class="h-2 w-1/2 bg-white/20 rounded-full"></div></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- 4. Nearby Iron Services -->
	<section id="nearby-services" class="py-24 bg-slate-50 border-t border-slate-200">
		<div class="max-w-7xl mx-auto px-6">
			<div class="text-center max-w-2xl mx-auto mb-16">
				<span class="inline-block px-4 py-1.5 rounded-full bg-white text-primary font-semibold text-sm mb-4 border border-slate-200 shadow-sm">Local Vendors</span>
				<h2 class="font-display text-3xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-6">Nearby Iron Services</h2>
				<p class="text-lg text-slate-600">Discover top-rated ironing professionals in your neighborhood, ready to pick up your clothes today.</p>
			</div>

			<div class="grid md:grid-cols-3 gap-8">
				<!-- Vendor 1 -->
				<div class="bg-white rounded-[2rem] p-6 border border-slate-100 shadow-xl shadow-slate-200/50 hover:-translate-y-1 transition-transform duration-300">
					<div class="h-40 bg-slate-100 rounded-xl mb-6 overflow-hidden relative">
						<div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1545173168-9f1947eebb7f?auto=format&fit=crop&q=80&w=800')] bg-cover bg-center"></div>
					</div>
					<div class="flex justify-between items-start mb-4">
						<div>
							<h3 class="font-bold text-xl text-slate-900">Shree Ram Ironing</h3>
							<p class="text-slate-500 text-sm flex items-center gap-1 mt-1"><span>📍</span> 0.5 km away • Vesu</p>
						</div>
						<div class="bg-emerald-50 text-emerald-700 font-bold px-2 py-1 rounded-lg text-sm flex items-center gap-1">
							⭐ 4.8
						</div>
					</div>
					<div class="flex items-center gap-4 text-sm text-slate-600 mb-6">
						<div class="flex items-center gap-1"><span>👕</span> ₹5/piece</div>
						<div class="flex items-center gap-1"><span>⚡</span> 24h return</div>
					</div>
					<button class="w-full py-3 rounded-xl font-bold bg-slate-50 text-primary border border-slate-200 hover:bg-primary hover:text-white transition-colors">Book Pickup</button>
				</div>
				<!-- Vendor 2 -->
				<div class="bg-white rounded-[2rem] p-6 border border-slate-100 shadow-xl shadow-slate-200/50 hover:-translate-y-1 transition-transform duration-300">
					<div class="h-40 bg-slate-100 rounded-xl mb-6 overflow-hidden relative">
						<div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1582735689149-c561646274e1?auto=format&fit=crop&q=80&w=800')] bg-cover bg-center"></div>
					</div>
					<div class="flex justify-between items-start mb-4">
						<div>
							<h3 class="font-bold text-xl text-slate-900">Mahadev Laundry</h3>
							<p class="text-slate-500 text-sm flex items-center gap-1 mt-1"><span>📍</span> 1.2 km away • Adajan</p>
						</div>
						<div class="bg-emerald-50 text-emerald-700 font-bold px-2 py-1 rounded-lg text-sm flex items-center gap-1">
							⭐ 4.9
						</div>
					</div>
					<div class="flex items-center gap-4 text-sm text-slate-600 mb-6">
						<div class="flex items-center gap-1"><span>👕</span> ₹6/piece</div>
						<div class="flex items-center gap-1"><span>⚡</span> 12h return</div>
					</div>
					<button class="w-full py-3 rounded-xl font-bold bg-slate-50 text-primary border border-slate-200 hover:bg-primary hover:text-white transition-colors">Book Pickup</button>
				</div>
				<!-- Vendor 3 -->
				<div class="bg-white rounded-[2rem] p-6 border border-slate-100 shadow-xl shadow-slate-200/50 hover:-translate-y-1 transition-transform duration-300">
					<div class="h-40 bg-slate-100 rounded-xl mb-6 overflow-hidden relative">
						<div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1610557892470-55d9e80c0bce?auto=format&fit=crop&q=80&w=800')] bg-cover bg-center"></div>
					</div>
					<div class="flex justify-between items-start mb-4">
						<div>
							<h3 class="font-bold text-xl text-slate-900">Krishna Dry Cleaners</h3>
							<p class="text-slate-500 text-sm flex items-center gap-1 mt-1"><span>📍</span> 2.0 km away • Piplod</p>
						</div>
						<div class="bg-emerald-50 text-emerald-700 font-bold px-2 py-1 rounded-lg text-sm flex items-center gap-1">
							⭐ 4.6
						</div>
					</div>
					<div class="flex items-center gap-4 text-sm text-slate-600 mb-6">
						<div class="flex items-center gap-1"><span>👕</span> ₹5/piece</div>
						<div class="flex items-center gap-1"><span>⚡</span> 24h return</div>
					</div>
					<button class="w-full py-3 rounded-xl font-bold bg-slate-50 text-primary border border-slate-200 hover:bg-primary hover:text-white transition-colors">Book Pickup</button>
				</div>
			</div>
			
			<div class="mt-12 text-center">
				<a href="#" class="inline-flex items-center gap-2 font-bold text-primary hover:text-accent transition-colors">
					View all vendors in Surat <span aria-hidden="true">&rarr;</span>
				</a>
			</div>
		</div>
	</section>

	<!-- 5. Vendor CTA -->
	<section id="vendor-cta" class="py-24 bg-white">
		<div class="max-w-7xl mx-auto px-6">
			<div class="bg-gradient-to-br from-indigo-50 to-sky-50 rounded-[3rem] p-10 md:p-16 border border-indigo-100 flex flex-col md:flex-row items-center justify-between gap-10">
				<div class="max-w-xl">
					<span class="inline-block px-4 py-1.5 rounded-full bg-indigo-100 text-indigo-700 font-semibold text-sm mb-6">For Ironing Professionals</span>
					<h2 class="font-display text-3xl md:text-4xl font-black text-slate-900 mb-4 tracking-tight">Grow your ironing business with Pressly.</h2>
					<p class="text-lg text-slate-600 mb-8 leading-relaxed">Join our network of verified vendors. Get more customers, manage orders digitally, and guarantee secure payments.</p>
					<ul class="flex flex-col gap-3 mb-8">
						<li class="flex items-center gap-3 text-slate-700"><span class="text-emerald-500 text-xl">✅</span> Zero onboarding fees</li>
						<li class="flex items-center gap-3 text-slate-700"><span class="text-emerald-500 text-xl">✅</span> Guaranteed weekly payouts</li>
						<li class="flex items-center gap-3 text-slate-700"><span class="text-emerald-500 text-xl">✅</span> Free partner app</li>
					</ul>
					<a href="/partner" class="inline-flex items-center justify-center px-8 py-4 rounded-2xl font-bold text-lg bg-indigo-600 text-white shadow-lg shadow-indigo-200 hover:-translate-y-1 hover:shadow-xl hover:shadow-indigo-300 transition-all duration-300">
						Become a Partner
					</a>
				</div>
				<div class="relative w-full max-w-sm hidden md:block">
					<div class="aspect-square bg-indigo-100 rounded-full flex items-center justify-center relative shadow-inner">
						<div class="absolute inset-10 bg-indigo-200 rounded-full animate-pulse"></div>
						<div class="text-[8rem] relative z-10 drop-shadow-2xl">🏪</div>
						<!-- Floating earnings badge -->
						<div class="absolute top-10 -left-6 bg-white px-4 py-3 rounded-2xl shadow-xl font-bold text-sm border border-slate-100 flex items-center gap-2 animate-[float_4s_ease-in-out_infinite]">
							<span class="text-emerald-500 bg-emerald-100 w-8 h-8 rounded-full flex items-center justify-center">₹</span>
							<div>
								<div class="text-xs text-slate-500 font-normal">Weekly Earnings</div>
								<div class="text-slate-900">₹12,450</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- 6. Customer CTA -->
	<section id="download" class="py-20 px-6">
		<div class="max-w-6xl mx-auto bg-slate-900 rounded-[3rem] p-12 md:p-20 text-center relative overflow-hidden shadow-2xl">
			<!-- Decorative Gradients -->
			<div class="absolute top-0 left-0 w-full h-full overflow-hidden z-0">
				<div class="absolute -top-[50%] -right-[20%] w-[80%] h-[150%] rounded-full bg-gradient-to-b from-primary/40 to-transparent blur-[100px] transform rotate-12"></div>
				<div class="absolute -bottom-[50%] -left-[20%] w-[80%] h-[150%] rounded-full bg-gradient-to-t from-accent/40 to-transparent blur-[100px] transform -rotate-12"></div>
			</div>
			
			<div class="relative z-10 max-w-3xl mx-auto">
				<h2 class="font-display text-4xl md:text-6xl font-black text-white mb-6 tracking-tight">Your laundry basket is waiting.</h2>
				<p class="text-xl text-slate-300 mb-12 leading-relaxed">Join thousands of users who have upgraded their daily routine. Get the Pressly app today and experience the magic of effortless ironing.</p>
				
				<div class="flex flex-col sm:flex-row justify-center gap-4">
					<button class="inline-flex items-center justify-center gap-3 px-8 py-4 rounded-2xl font-bold text-lg bg-white text-slate-900 hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
						<span class="text-2xl">🍎</span> App Store
					</button>
