---
import Logo from '../components/Logo.astro';
import XIcon from '../components/icons/XIcon.astro';
import InstagramIcon from '../components/icons/InstagramIcon.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
	schema?: string;
}

const { 
	title, 
	description = "Pressly - Professional on-demand doorstep ironing services. Schedule a pickup, count your clothes at the door, and track delivery in real time.",
	image = "/og-image.png",
	schema
} = Astro.props;

// Construct full URLs using the configured site domain
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://pressly.app');
const socialImageURL = new URL(image, Astro.site || 'https://pressly.app');

// Default Schema if none provided
const defaultSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	"name": "Pressly",
	"image": socialImageURL.toString(),
	"description": description,
	"url": "https://pressly.app",
	"priceRange": "$",
	"address": {
		"@type": "PostalAddress",
		"addressLocality": "Surat",
		"addressRegion": "Gujarat",
		"addressCountry": "IN"
	}
});
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImageURL} />
		
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalURL} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageURL} />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={schema || defaultSchema} />
		
		<!-- Sitemap -->
		<link rel="sitemap" href="/sitemap-index.xml" />
		
		<!-- Global Event Tracking -->
		<script is:inline>
			window.trackEvent = function(eventName, eventData = {}) {
				// Console log for debugging
				console.log(`[Event Tracked] ${eventName}:`, eventData);
				
				// Cloudflare Web Analytics (if Zaraz or custom setup is added later)
				if (typeof zaraz !== 'undefined') {
					zaraz.track(eventName, eventData);
				}
				
				// Google Analytics Fallback (if added later)
				if (typeof gtag !== 'undefined') {
					gtag('event', eventName, eventData);
				}
				
				// PostHog Fallback (if added later)
				if (typeof posthog !== 'undefined') {
					posthog.capture(eventName, eventData);
				}
			};

			// Global listener for FAQ tracking
			document.addEventListener('DOMContentLoaded', () => {
				const detailsElements = document.querySelectorAll('details');
				detailsElements.forEach(detail => {
					detail.addEventListener('toggle', (e) => {
						if (detail.open) {
							// Find the question text (summary)
							const summary = detail.querySelector('summary');
							const questionText = summary ? summary.textContent.trim() : 'Unknown Question';
							
							window.trackEvent('faq_expand', { question: questionText });
						}
					});
				});
			});
		</script>
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;700;800;900&display=swap" rel="stylesheet" />
	</head>
	<body class="min-h-screen flex flex-col font-sans text-slate-900 bg-white antialiased selection:bg-primary/20 selection:text-primary">
		<!-- Navigation Header with Glassmorphism -->
		<header class="fixed top-0 left-0 w-full h-[80px] bg-white/40 backdrop-blur-md border-b border-white/30 z-50 flex items-center transition-all duration-300">
			<div class="max-w-7xl mx-auto px-6 w-full flex justify-between items-center">
				<a href="/" class="flex items-center gap-2 no-underline">
					<Logo />
				</a>
				<nav class="hidden md:flex gap-8">
					<a href="/#how-it-works" class="text-slate-600 font-medium text-sm hover:text-primary transition-colors relative group">
						How it Works
						<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary rounded-full transition-all duration-300 group-hover:w-full"></span>
					</a>
					<a href="/faq" class="text-slate-600 font-medium text-sm hover:text-primary transition-colors relative group">
						FAQ
						<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary rounded-full transition-all duration-300 group-hover:w-full"></span>
					</a>
					<a href="/contact" class="text-slate-600 font-medium text-sm hover:text-primary transition-colors relative group">
						Contact
						<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-primary rounded-full transition-all duration-300 group-hover:w-full"></span>
					</a>
				</nav>
				<div class="flex items-center gap-4">
					<a href="/vendor" onclick="if(typeof window.trackEvent === 'function') window.trackEvent('cta_click', { location: 'header', type: 'partner' })" class="hidden md:inline-flex items-center justify-center px-4 py-2 rounded-xl font-semibold text-sm bg-white/40 backdrop-blur-md text-slate-800 border border-slate-300/80 hover:bg-white/60 hover:-translate-y-0.5 transition-all">Partner With Us</a>
					<a href="#download" onclick="if(typeof window.trackEvent === 'function') window.trackEvent('cta_click', { location: 'header', type: 'download' })" class="inline-flex items-center justify-center px-5 py-2.5 rounded-xl font-semibold text-sm bg-slate-900 text-white shadow-sm hover:bg-slate-800 hover:-translate-y-0.5 transition-all">Get the App</a>
				</div>
			</div>
		</header>

		<main class="mt-[80px] flex-1">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="bg-slate-50 border-t border-slate-200 pt-20 pb-8 mt-auto">
			<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 mb-16">
				<div class="lg:col-span-2">
					<div class="mb-4">
						<a href="/" class="flex items-center gap-2 no-underline">
							<Logo />
						</a>
					</div>
					<p class="text-slate-600 text-sm leading-relaxed max-w-xs">Redefining laundry care with transparent doorstep counting and live tracking.</p>
				</div>
				<div class="flex flex-col gap-1">
					<h4 class="font-display font-bold text-slate-900 mb-2">Customers</h4>
					<a href="/#features" class="block py-2 text-slate-600 text-sm hover:text-primary hover:translate-x-1 transition-all">App Features</a>
					<a href="/#how-it-works" class="block py-2 text-slate-600 text-sm hover:text-primary hover:translate-x-1 transition-all">How it Works</a>
					<a href="/faq" class="block py-2 text-slate-600 text-sm hover:text-primary hover:translate-x-1 transition-all">FAQ</a>
				</div>
				<div class="flex flex-col gap-1">
					<h4 class="font-display font-bold text-slate-900 mb-2">Partners</h4>
					<a href="/vendor" class="block py-2 text-slate-600 text-sm hover:text-primary hover:translate-x-1 transition-all">Join as Vendor</a>
					<a href="/vendor#benefits" class="block py-2 text-slate-600 text-sm hover:text-primary hover:translate-x-1 transition-all">Benefits</a>
				</div>
				<div class="flex flex-col gap-1">
					<h4 class="font-display font-bold text-slate-900 mb-2">Company</h4>
					<a href="/about" class="block py-2 text-slate-600 text-sm hover:text-primary hover:translate-x-1 transition-all">About Us</a>
					<a href="/contact" class="block py-2 text-slate-600 text-sm hover:text-primary hover:translate-x-1 transition-all">Contact</a>
					<a href="/privacy" class="block py-2 text-slate-600 text-sm hover:text-primary hover:translate-x-1 transition-all">Privacy Policy</a>
					<a href="/terms" class="block py-2 text-slate-600 text-sm hover:text-primary hover:translate-x-1 transition-all">Terms of Service</a>
				</div>
			</div>
			<div class="max-w-7xl mx-auto px-6 border-t border-slate-200 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-slate-400 text-sm">
				<p>&copy; {new Date().getFullYear()} Pressly Inc. All rights reserved.</p>
				<div class="flex items-center gap-6 text-slate-500">
					<a href="#" aria-label="Twitter" class="p-3 -m-3 hover:text-primary transition-colors"><XIcon class="w-5 h-5" /></a>
					<a href="#" aria-label="Instagram" class="p-3 -m-3 hover:text-primary transition-colors"><InstagramIcon class="w-5 h-5" /></a>
				</div>
			</div>
		</footer>

		<!-- Cloudflare Web Analytics -->
		<!-- TODO(Pre-Launch): Update 'YOUR_CLOUDFLARE_TOKEN_HERE' with your actual token from the Cloudflare Dashboard once domain is purchased -->
		<script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "YOUR_CLOUDFLARE_TOKEN_HERE"}'></script>
		<!-- End Cloudflare Web Analytics -->
	</body>
</html>
